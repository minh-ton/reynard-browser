    "Use Android User Agent" : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用Android 用户代理(UA)"
          }
        }
      }
    },
    "UseAndroidUserAgentFooterText" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To maximize compatibility, the browser will use the Firefox for Android user agent for navigating the web. As a result, websites may identify your device as an Android device."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "为了最大限度地提高兼容性，浏览器将使用 Firefox for Android 用户代理(UA)进行网页浏览。因此网站可能会将您的设备识别为 Android 设备。"
          }
        }
      }
    },
    "UseFirefoxUserAgentFooterText" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The browser will use a desktop Firefox user agent for navigating the web."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "浏览器将使用桌面版 Firefox 用户代理(UA)进行网页浏览。"
          }
        }
      }
    },
    "User Agent Overrides" : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用户代理(UA)覆写"
          }
        }
      }
    },
    "UserAgentOverridesFooterText" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you encounter issues such as sign-in failures, human verification challenges, or other incorrect site behavior, adding the site's URL to this user agent override list may help resolve the problem."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "若遇到登录失败、机器人验证或网站功能异常等问题，可将该网站网址添加至用户代理改写列表来尝试修复。"
          }
        }
      }
    },
    "UserAgentOverridesWebsiteFooterText" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Navigations to these websites will use the browser's compatibility user agent. Depending on your Request Desktop Website setting, these websites may identify your device as either an Android device or a desktop Linux device."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "访问这些网站时，将使用浏览器的兼容性用户代理(UA)。根据您的“请求桌面网站”设置，这些网站可能会将您的设备识别为 Android 设备或 Linux 桌面设备。"
          }
        }
      }
    },
