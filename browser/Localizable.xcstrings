    "AboutDeveloperMessage" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hi, I'm Minh, the developer of Reynard. If you find the project useful, sponsoring me helps keep it alive and maintained. Thanks for the support!"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您好,我是Reynard的开发者Minh。如果您觉得这个项目有用，您可以赞助我有助于保持该项目的活跃和维护。感谢您的支持！"
          }
        }
