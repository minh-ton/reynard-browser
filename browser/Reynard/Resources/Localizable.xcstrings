    "Reynard won’t remember any of your browsing history or cookies. However, downloads and new bookmarks will be saved." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reynard won’t remember any of your browsing history or cookies. However, downloads and new bookmarks will be saved."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reynard ne conservera pas votre historique de recherche ou vos cookies. Cependant, vos téléchargements et les marques pages ajoutés seront conservés. "
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reynard 不会记住任何浏览历史记录或 Cookie。但是，下载项目和新书签仍会保留。"
          }
        }
      }
    },
