    "Install the TrollStore version of Reynard to enable JIT automatically for improved performance and to ensure websites work properly." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Install the TrollStore version of Reynard to enable JIT automatically for improved performance and to ensure websites work properly."
