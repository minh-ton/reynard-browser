    "Stronger tracking protection and faster performance, but some websites may not work properly." : {
      "localizations" : {
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ጠንካራ የመከታተያ ጥበቃ እና ፈጣን አፈጻጸም፣ ነገር ግን አንዳንድ ጣቢያዎች በትክክል ላይሰሩ ይችላሉ።"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حماية أقوى ضد المتعقّبات وأداء أسرع، لكن قد لا تشتغل بعض المواقع بشكل صحيح."
          }
        },
        "be" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Мацнейшая ахова ад сачэння і лепшая хуткадзейнасць, але некаторыя сайты могуць не працаваць належным чынам."
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "По-силна защита от проследяване и по-бърза производителност, но някои сайтове може да не работят правилно."
          }
        },
        "br" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gwarez heuliañ kreñvoc’h ha digonusted gwelloc’h, met lec’hiennoù ’zo a c’hallo chom hep mont en-dro."
          }
        },
        "bs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jača zaštita od praćenja i brže performanse, ali neke web stranice možda neće raditi ispravno."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Més protecció i millor rendiment, però pot fer que alguns llocs no funcionin correctament."
          }
        },
        "co" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una prutezzione più forte contr’à u spiunagiu è perfurmenze piu rapide, ma certi siti ponu ùn micca funziunà currettamente."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Silnější ochrana, která zlepšuje rychlost načítání stránek. Může ale omezit jejich fungování."
          }
        },
        "cy" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diogelwch tracio cryfach a pherfformiad cyflymach, ond efallai na fydd rhai gwefannau’n gweithio’n iawn."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stærkere beskyttelse mod sporing og hurtigere ydelse, men nogle websteder virker måske ikke ordentligt."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stärkerer Tracking-Schutz und schnellere Leistung, aber einige Websites funktionieren möglicherweise nicht richtig."
          }
        },
        "dsb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mócnjejšy slědowański šćit a malsnjejše wugbaśe, ale někotare sedła snaź pórědnje njefunlcioněruju."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ισχυρότερη προστασία από καταγραφή και καλύτερες επιδόσεις, αλλά ορισμένοι ιστότοποι ενδέχεται να μην λειτουργούν σωστά."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stronger tracking protection and faster performance, but some websites may not work properly."
          }
        },
        "en-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stronger tracking protection and faster performance, but some websites may not work properly."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stronger tracking protection and faster performance, but some websites may not work properly."
          }
        },
        "eo" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plej bona protekto kontraŭ spurado, kaj plej bona efikeco, sed kelkaj retejoj povus ne bone funkcii."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Protección contra rastreo mejorada y mayor rendimiento, pero puede que algunos sitios no funcionen correctamente."
          }
        },
        "es-AR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mayor protección de rastreo y rendimiento más rápido, pero algunos sitios pueden no funcionar correctamente."
          }
        },
        "es-CL" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una mayor protección de seguimiento y un mejor rendimiento, pero algunos sitios podrían no funcionar adecuadamente."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Protección contra rastreo mejorada y mayor rendimiento, pero puede que algunos sitios no funcionen correctamente."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Protección contra rastreo mejorada y mayor rendimiento, pero puede que algunos sitios no funcionen correctamente."
          }
        },
        "et" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tugevam jälitamisvastane kaitse ja suurem jõudlus, kuid mõned saidid ei pruugi korralikult töötada."
          }
        },
        "eu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jarraipenaren babes sendoagoa eta errendimendu hobea baina baliteke zenbait gune ondo ez ibiltzea."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "محافظت از ردیابی قوی‌تر و کارایی سریع‌تر ، اما برخی از پایگاه‌ها ممکن است به درستی کار نکنند."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vahvempi seurantasuojaus ja nopeampi suorituskyky, mutta jotkin sivustot eivät välttämättä toimi kunnolla."
          }
        },
        "fil" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mas malakas na proteksyon laban sa mga tracker at mas mabilis na performance, pero baka may mga site na hindi gumana nang maayos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une protection renforcée contre le pistage et de meilleures performances, mais certains sites peuvent ne pas fonctionner correctement."
          }
        },
        "fur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Protezion da lis spiis plui potente e prestazions plui sveltis, ma al è pussibil che cualchi sît nol funzioni ben."
          }
        },
        "fy-NL" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sterkere beskerming tsjin folgjen en fluggere prestaasjes, mar guon websites wurkje mooglik net goed."
          }
        },
        "gd" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dìon o thracadh agus dèanadas nas fheàrr ach bidh làraichean ann nach obraich buileach mar bu chòir."
          }
        },
        "gl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maior protección contra o rastrexo e mellor rendemento, pero é posible que algúns sitios non funcionen correctamente."
          }
        },
        "gn" : {
          "stringUnit" : {
