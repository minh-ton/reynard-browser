    "Stops outside ads, videos, and other content from loading that contains tracking code. May affect some website functionality." : {
      "localizations" : {
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ከማስታወቂያዎች፣ ቪዲዮዎች እና ሌሎች የክትትል ኮድ የያዙ ሌሎች ይዘቶችን ከመጫን ያቆማል። አንዳንድ የድረ-ገጽ ተግባራትን ሊጎዳ ይችላል።"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "توقيف تحميل الإعلانات والفيديوهات وغيرها من محتويات خارجية تحتوي على برمجيات تعقّب. قد يؤثّر هذا على سلوك بعض المواقع."
          }
        },
        "ast" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para la carga d'anuncios, vídeos y otru conteníu esternu que contenga códigu que rastrexe. Ye posible qu'afeute a les funciones de dalgunos sitios web."
          }
        },
        "be" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Спыняе загрузку вонкавай рэкламы, відэа і іншага змесціва, якое змяшчае код асочвання. Можа адбіцца на некаторых функцыях вэб-сайта."
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Спира зареждането на външни реклами, видео и друго съдържание, съдържащо проследяващ код. Може да засегне някои страници."
          }
        },
        "br" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Harzañ a ra ar bruderezh diavaez hag an endalc’hadoù all da gargañ a endalc’h ur boneg heuliañ. Gallout a ra kaout un efed war mont-en-dro lec’hiennoù ’zo."
          }
        },
        "bs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zaustavlja reklame, video, i druge sadržaje koji sadrže kod za praćenje. Može uticati na funkcionisanje nekih web stranica."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impedeix que es carreguin anuncis, vídeos i altre contingut que contenen codi de seguiment. Pot afectar la funcionalitat del lloc web."
          }
        },
        "co" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impedisce u caricamentu di e publicità, video è altri cuntenuti d’origine esterna à u situ è cuntenendu codice di spiunagiu. Què pò affettà certe funzioni di u situ web."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Blokuje načítání reklam, videí a dalšího obsahu, který obsahuje sledující kód. To může ovlivnit fungování některých webových stránek."
          }
        },
        "cy" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yn rhwystro hysbysebion, fideos, a chynnwys allanol arall rhag llwytho’r hyn sy’n cynnwys cod tracio. Gall effeithio ar rywfaint o ymarferoldeb gwefan."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stopper indlæsning af eksterne reklamer, videoer og andet indhold, der indeholder sporings-kode. Kan påvirke nogle websteders funktionalitet."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verhindert das Laden von Werbung, Videos und anderen Inhalten, die Skripte zur Aktivitätenverfolgung enthalten. Kann einige Funktionen der Website beeinträchtigen."
          }
        },
        "dsb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zaźujo zacytanjeju wabjenja, wideo a drugego wopśimjeśa, kótarež slědowański kod wopśimuju. Móžo někotare funkcije websedłow kazyś."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Διακόπτει τη φόρτωση εξωτερικών διαφημίσεων, βίντεο και άλλου περιεχομένου που περιέχει κώδικα καταγραφής. Ίσως επηρεάσει τη λειτουργικότητα ορισμένων ιστοτόπων."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stops outside ads, videos, and other content from loading that contains tracking code. May affect some website functionality."
          }
        },
        "en-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stops outside ads, videos, and other content from loading that contains tracking code. May affect some website functionality."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stops outside ads, videos, and other content from loading that contains tracking code. May affect some website functionality."
          }
        },
        "eo" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Haltigo de ŝargado de nerektaj reklamoj, filmetoj kaj aliaj enhavoj, kiuj portas spurilan kodon. Tio povas misfunkciigi kelkajn trajtojn de retejoj."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bloquea la carga de anuncios externos, vídeos y contenido que contenga código de rastreo. Puede afectar a la funcionalidad del sitio web."
          }
        },
        "es-AR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Detiene la carga de anuncios externos, videos y otro contenido que contiene código de rastreo. Puede afectar la funcionalidad del sitio web."
          }
        },
        "es-CL" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Detiene la carga de publicidad, videos y otros contenidos que contienen códigos de seguimiento. Puede afectar la funcionalidad de algunos sitios web."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bloquea la carga de anuncios externos, vídeos y contenido que contenga código de rastreo. Puede afectar a la funcionalidad del sitio web."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bloquea la carga de anuncios externos, vídeos y contenido que contenga código de rastreo. Puede afectar a la funcionalidad del sitio web."
          }
        },
        "et" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Peatab jälitavat koodi sisaldavate reklaamide, videote ja muu sisu laadimise. Võib mõjutada mõnda veebisaidi funktsionaalsust."
          }
        },
        "eu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jarraipenerako kodea izan lezaketen kanpoko iragarkiak, bideoak eta bestelako edukia kargatzea eragozten du. Zenbait webguneren eginbideetan eragina izan lezake."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "از بارگیری که حاوی کد رهگیری است، خارج از تبلیغات، ویدیوها و سایر مطالب متوقف می‌شود. ممکن است بر عملکرد وبگاه تأثیر بگذارد."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estää lataamasta ulkopuolisia mainoksia, videoita ja muuta sisältöä, joka sisältää seurantakoodin. Voi vaikuttaa joidenkin verkkosivustojen toimimiseen."
          }
        },
        "fil" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pinipigilang mag-load ang mga panlabas na mga ad, video, at iba pang content na nagtataglay ng tracking code. Maaaring maapektuhan ang ilang aspeto ng website."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Empêche le chargement des publicités, vidéos et autres contenus d’origine externe au site et contenant du code de pistage. Peut affecter certaines fonctionnalités du site."
          }
        },
        "fur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Al ferme il cjariament di publicitâts esternis, videos e altris contignûts che a contegnin codiç che ti spie. Al pues influençâ cualchi funzionalitât dal sît web."
          }
        },
        "fy-NL" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Foarkomt dat eksterne advertinsjes, fideo’s en oare ynhâld dy’t folchkoade befettet laden wurde. Kin ynfloed hawwe op de funksjonaliteit fan guon websites."
          }
        },
        "ga-IE" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuireann sé seo cosc ar fhógraí, ar fhíseáin, agus ar ábhar eile a bhfuil cód lorgaireachta ann. Imríonn sé tionchar ar fheidhmíocht suíomh áirithe."
          }
        },
        "gd" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuiridh seo stad air luchdadh de shanasachd, videothan is susbaint eile on taobh a-muigh anns a bheil còd tracaidh. Dh’fhaoidte gum bi droch-bhuaidh aige seo air obrachadh de chuid a làraichean-lìn."
          }
        },
        "gl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Detén a carga de anuncios, vídeos e outros contidos que conteñan código de seguimento. Pode afectar a algunhas funcións dos sitios web."
          }
        },
        "gn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ejoko ñemurã ñemyanyhẽ okayguáva, ta’ãngamýi ha tetepy oguerekóva ayvu rapykuehoha. Ikatu ombyai ñanduti renda rembiapoite."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "עוצר טעינה של פרסומות, סרטונים וכל תוכן חיצוני אחר שמכיל קוד מעקב. עשוי להשפיע על אופן פעילות האתר."
          }
        },
        "hi-IN" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "जिसमें ट्रैकिंग कोड होता है उसे बाहरी विज्ञापन, वीडियो, और अन्य सामग्री लोड करने से रोकती है। कुछ वेबसाइट की कार्यक्षमता को प्रभावित करती हैं।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zaustavlja učitavanje vanjskih oglasa, videozapisa i drugog sadržaja koji sadrži kod za praćenje. Može utjecati na neke funkcionalnosti web stranice."
          }
        },
        "hsb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zadźěwa začitanju wabjenja, widejow a druheho wobsaha, kotrež slědowanski kod wobsahuja. Móže někotrym funkcijam websydłow wadźić."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
