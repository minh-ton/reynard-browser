        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "No s’ha pogut baixar aquesta extensió perquè s’ha produït un problema de connexió."
          }
        },
        "co": {
          "stringUnit": {
            "state": "translated",
            "value": "St’estensione ùn pò micca esse scaricata per via d’un fiascu di cunnessione."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Toto rozšíření se nepodařilo stáhnout z důvodu selhání připojení."
          }
        },
        "cy": {
          "stringUnit": {
            "state": "translated",
            "value": "Nid oedd modd llwytho'r estyniad hwn i lawr oherwydd gwall cysylltiad."
          }
        },
        "da": {
