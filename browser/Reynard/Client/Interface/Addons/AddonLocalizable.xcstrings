    "This add-on was blocked for violating Mozilla’s policies and has been disabled.": {
      "localizations": {
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "ይህ ቅጥያ የMozilla መመሪያዎችን ስለጣሰ ታግዷል እና ተሰናክሏል።"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حُظِر هذا الامتداد بسبب انتهاكه لسياسات Mozilla وتم تعطيله."
          }
        },
        "ast": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta estensión ta bloquiada por incumplir les polítiques de Mozilla y desactivóse."
          }
        },
        "be": {
          "stringUnit": {
            "state": "translated",
            "value": "Гэта пашырэнне заблакавана за парушэнне палітык Mozilla і было адключана."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Разширението е забранено поради нарушение на политиките на Mozilla и е изключено."
          }
        },
        "br": {
          "stringUnit": {
            "state": "translated",
            "value": "Stanket eo an adkouezh-mañ dre ma za a-enep da bolitikerezh Mozilla ha diweredekaet eo bet."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Ova ekstenzija je blokirana zbog kršenja Mozilla pravila i onemogućena je."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Aquesta extensió s’ha blocat perquè infringeix les polítiques de Mozilla i s’ha desactivat."
          }
        },
        "co": {
          "stringUnit": {
            "state": "translated",
            "value": "St’estensione hè stata bluccata perchè trasgredisce e regule di Mozilla è tandu hè stata disattivata."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Toto rozšíření bylo zablokováno z důvodu porušování pravidel Mozilly a bylo zakázáno."
          }
        },
        "cy": {
          "stringUnit": {
            "state": "translated",
            "value": "Mae'r estyniad hwn wedi'i rwystro am fynd yn groes i bolisïau Mozilla ac mae wedi'i analluogi."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Denne udvidelse er blokeret for at overtræde Mozillas politikker og er blevet deaktiveret."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Erweiterung wurde wegen Verstoßes gegen Mozillas Richtlinien blockiert und deaktiviert."
          }
        },
        "dsb": {
          "stringUnit": {
            "state": "translated",
            "value": "Toś to rozšyrjenje jo dla pśejźenja pśeśiwo pšawidłam Mozilla blokěrowane a jo se znjemóžniło."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αυτή η επέκταση έχει αποκλειστεί επειδή παραβιάζει τις πολιτικές της Mozilla και έχει απενεργοποιηθεί."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This add-on was blocked for violating Mozilla’s policies and has been disabled."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "This add-on is blocked for violating Mozilla’s policies and has been disabled."
