    "Allow unverified third-party scripts to access your data": {
      "localizations": {
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "ያልተረጋገጡ የሶስተኛ ወገን ስክሪፕቶች የእርስዎን ውሂብ እንዲደርሱበት ይፍቀዱ"
