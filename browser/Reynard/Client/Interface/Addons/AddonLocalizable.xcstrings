    "This add-on couldn’t be downloaded because of a connection failure.": {
      "localizations": {
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "በግንኙነት ችግር ምክንያት ይህ ቅጥያ ሊወርድ አልቻለም።"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذر تنزيل الامتداد بسبب فشل في الاتصال."
          }
        },
        "ast": {
          "stringUnit": {
            "state": "translated",
            "value": "Nun se pudo baxar esta estensión por un fallu de la conexón."
          }
        },
        "be": {
          "stringUnit": {
            "state": "translated",
            "value": "Немагчыма сцягнуць гэтае пашырэнне, бо злучэнне не ўдалося."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Разширението не може да бъде изтеглено поради неуспешно установена връзка."
          }
        },
        "br": {
          "stringUnit": {
            "state": "translated",
            "value": "An askouezh-mañ n’hall ket bezañ pellgarget en abeg d’ur fazi kennask."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Ovu ekstenziju nije bilo moguće preuzeti zbog neuspjeha veze."
