        },
        "co": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ ùn pò micca esse installatu perchè a so installazione si pò fà solu da un urganismu impieghendu strategie d’impresa, ciò chì ùn hè micca accettatu nant’à sta piattaforma."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
