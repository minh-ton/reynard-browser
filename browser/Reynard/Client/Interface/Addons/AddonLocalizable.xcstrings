    },
    "Unverified scripts can pose security and privacy risks. Only allow scripts from add-ons or sources you trust.": {
      "localizations": {
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "ያልተረጋገጡ ስክሪፕቶች የደህንነት እና የግላዊነት አደጋዎችን ሊያስከትሉ ይችላሉ። ስክሪፕቶችን ከቅጥያዎች ወይም ከምታምኗቸው ምንጮች ብቻ አሂድ።"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قد تُشكّل السكربتات غير الموثوقة مخاطر على الأمن والخصوصية. شغّل السكربتات فقط من الامتدادات أو المصادر التي تثق بها."
          }
        },
        "ast": {
          "stringUnit": {
            "state": "translated",
            "value": "Los scripts non verificaos puen suponer un riesgu de seguranza y privacidá. Executa namás los scripts d'estensiones o fontes nes que t'enfotes."
          }
        },
        "be": {
          "stringUnit": {
            "state": "translated",
            "value": "Неправераныя скрыпты могуць пагражаць бяспецы і прыватнасці. Запускайце скрыпты толькі з пашырэнняў ці крыніц, якім давяраеце."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Непроверените скриптове могат да представляват рискове за сигурността и поверителността. Изпълнявайте само скриптове от разширения или източници, на които имате доверие."
          }
        },
        "br": {
          "stringUnit": {
            "state": "translated",
            "value": "Skriptoù n'int ket gwiriekaet a c'hall sevel kudennoù diogelroez ha buhez prevez. Erounit skriptoù askouezhioù pe mammennoù ho peuz fiziañs eno."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Neprovjerene skripte mogu predstavljati rizik za sigurnost i privatnost. Pokreni samo skripte iz ekstenzija ili izvora kojima vjeruješ."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Els scripts no verificats poden comportar riscos de seguretat i de privadesa. Executeu només els scripts procedents d’extensions o de fonts de confiança."
          }
        },
        "co": {
          "stringUnit": {
            "state": "translated",
            "value": "I scenarii micca verificati ponu pone prublemi di sicurità è di cunfidenzialità. Fate funziunà solu scenarii chì venenu da estensioni o fonti per quelli vo site cunfidenti."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Neověřené skripty mohou představovat bezpečnostní rizika a rizika pro soukromí. Spouštějte skripty pouze z rozšíření nebo zdrojů, kterým důvěřujete."
          }
        },
        "cy": {
          "stringUnit": {
            "state": "translated",
            "value": "Gall sgriptiau heb eu gwirio achosi risgiau diogelwch a phreifatrwydd. Cofiwch redeg dim ond sgriptiau o estyniadau neu ffynonellau rydych chi'n ymddiried ynddyn nhw."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Ubekræftede scripts kan udgøre en risiko for din sikkerhed eller beskyttelsen af dit privatliv. Kør kun scripts fra udvidelser eller kilder, du stoler på."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nicht verifizierte Skripte können Risiken für Sicherheit und Datenschutz darstellen. Führen Sie nur Skripte von Erweiterungen oder Quellen aus, denen Sie vertrauen."
          }
        },
        "dsb": {
          "stringUnit": {
            "state": "translated",
            "value": "Njepśeglědane skripty mógu rizika za wěstotu a priwatnosć byś. Wuwjeźćo jano skripty z rozšyrjenjow abo žrědłow, kótarymž dowěriśo."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Τα μη επαληθευμένα σενάρια μπορούν να θέσουν σε κίνδυνο την ασφάλεια και το απόρρητό σας. Να εκτελείτε σενάρια μόνο από επεκτάσεις ή πηγές που εμπιστεύεστε."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unverified scripts can pose security and privacy risks. Only allow scripts from add-ons or sources you trust."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Unverified scripts can pose security and privacy risks. Only run scripts from add-ons or sources you trust."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Unverified scripts can pose security and privacy risks. Only run scripts from add-ons or sources you trust."
          }
        },
        "eo": {
          "stringUnit": {
            "state": "translated",
            "value": "Nekontrolitaj skriptoj povas prezenti sekurecajn kaj privatecajn riskojn. Nur rulu skriptojn de etendaĵoj aŭ fontoj, kiujn vi fidas."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los scripts no verificados pueden representar riesgos de seguridad y privacidad. Solo ejecuta scripts de extensiones o fuentes en las que confías."
          }
        },
        "es-AR": {
          "stringUnit": {
            "state": "translated",
            "value": "Los scripts no verificados pueden representar riesgos de seguridad y privacidad. Solo ejecutá scripts de extensiones o fuentes en las que confíés."
          }
        },
        "es-CL": {
          "stringUnit": {
            "state": "translated",
            "value": "Los scripts no verificados pueden suponer riesgos de seguridad y privacidad. Ejecuta únicamente scripts de extensiones o fuentes en las que confíes."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Los scripts no verificados pueden representar riesgos de seguridad y privacidad. Solo ejecuta scripts de extensiones o fuentes en las que confías."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Los scripts no verificados pueden suponer riesgos de seguridad y privacidad. Ejecuta únicamente scripts de extensiones o fuentes en las que confíes."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Kontrollimata skriptid võivad olla turva- ja privaatsusriskiks. Käita skripte ainult usaldusväärsetest laiendustest ja allikatest."
          }
        },
        "eu": {
          "stringUnit": {
            "state": "translated",
            "value": "Egiaztatu gabeko scriptek segurtasun eta pribatutasun arriskuak eragin litzakete. Soilik exekutatu hedapenetako edo fidagarritzat dituzun iturburuetako scriptak."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "اسکریپت‌های تایید نشده می‌توانند خطرات امنیتی و حفظ حریم خصوصی ایجاد کنند. فقط اسکریپت‌هایی را از افزونه‌ها یا منابعی که به آن‌ها اعتماد دارید، اجرا کنید."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Vahvistamattomat komentosarjat voivat aiheuttaa turvallisuus- ja tietosuojariskejä. Suorita komentosarjoja vain laajennuksista tai lähteistä, joihin luotat."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Maaaring maging panganib sa seguridad at pribasiya ang mga di-beripikadong script. Magpatakbo lang ng mga script mula sa mga extension na pinagkakatiwalaan mo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les scripts non vérifiés peuvent poser des problèmes de sécurité et de confidentialité. N’exécutez que des scripts provenant d’extensions ou de sources auxquelles vous faites confiance."
          }
        },
        "fur": {
          "stringUnit": {
            "state": "translated",
            "value": "I scripts no verificâts a puedin compuartâ risis pe sigurece e la riservatece. Eseguìs scripts dome di estensions o origjins afidabilis."
          }
        },
        "fy-NL": {
          "stringUnit": {
            "state": "translated",
            "value": "Net ferifiearre scripts kinne befeiligings- en privacyrisiko’s foarmje. Fier allinnich scripts út fan útwreidingen of boarnen dy’'t jo fertrouwe."
          }
        },
        "gd": {
          "stringUnit": {
            "state": "translated",
            "value": "Dh’fhaoidte gum bi sgriobtaichean gun dearbhadh cunnartach a thaobh tèarainteachd is prìobhaideachd. Na ruith ach sgriobtaichean aig leudachain no o thùsan sa bheil earbsa agad."
          }
        },
        "gl": {
          "stringUnit": {
            "state": "translated",
            "value": "Os scripts non verificados poden supor riscos de seguridade e privacidade. Executa só scripts de extensións ou fontes de confianza."
          }
        },
        "gn": {
          "stringUnit": {
            "state": "translated",
            "value": "Umi scripts ojehechajey’ỹva ikatu omboyke tekorosã ha tekoñemi. Omongu’e scripts jepysokue térã teñoiha ejeroviaha."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "תסריטים שאינם מאומתים עלולים להוות סיכוני אבטחה ופרטיות. יש להריץ תסריטים מהרחבות או מקורות מהימנים בלבד."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Neprovjerena skripta mogu predstavljati rizike za sigurnost i privatnost. Pokreći samo skripta iz proširenja ili izvora kojima vjeruješ."
          }
        },
        "hsb": {
          "stringUnit": {
            "state": "translated",
            "value": "Njepřepruwowane skripty móža rizika za wěstotu a priwatnosć być. Wuwjedźće jenož skripty z rozšěrjenjow abo žórłow, kotrymž dowěrjeće."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A nem ellenőrzött parancsfájlok biztonsági és adatvédelmi kockázatot jelenthetnek. Csak olyan kiegészítőkből vagy forrásokból futtasson parancsfájlokat, melyekben megbízik."
          }
        },
        "hy-AM": {
          "stringUnit": {
            "state": "translated",
            "value": "Չստուգված սկրիպտները կարող են անվտանգության և գաղտնիության վտանգներ առաջացնել: Աշխատեցրեք սկրիպտներ միայն ընդլայնումներից կամ աղբյուրներից, որոնց վստահում եք:"
          }
        },
        "ia": {
          "stringUnit": {
            "state": "translated",
            "value": "Le scripts non verificate pote poner riscos de securitate e confidentialitate. Solo exeque scripts de extensiones o fontes cuje tu te fide."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Skrip yang tidak diverifikasi dapat menimbulkan risiko keamanan dan privasi. Hanya jalankan skrip dari ekstensi atau sumber yang Anda percayai."
          }
        },
        "is": {
          "stringUnit": {
            "state": "translated",
            "value": "Óstaðfestar skriftur geta valdið öryggis- og persónuverndaráhættu. Keyrðu aðeins skriftur frá viðbótum eða uppruna sem þú treystir."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Script non verificati possono comportare rischi per la sicurezza e la privacy. Esegui script solo da estensioni o fonti attendibili."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "未検証のスクリプトはユーザーの安全とプライバシーに危険を及ぼす可能性があります。拡張機能や信頼できるソースからのスクリプト以外は実行しないでください。"
          }
        },
        "ka": {
          "stringUnit": {
            "state": "translated",
            "value": "გადაუმოწმებელ სკრიპტებს შეუძლია საფრთხე შეუქმნას უსაფრთხოებასა და პირადულობას. სკრიპტების გაშვების ნება დართეთ მხოლოდ იმ გაფართოებებსა თუ წყაროებს, რომელთაც ენდობით."
          }
        },
        "kab": {
          "stringUnit": {
            "state": "translated",
            "value": "Iskripten ur nettwasenqed ara zemren ad qemmṛen s tɣellist d uqader n tmeddurt tusligt. Selkem ala iskripten i d-yettwawin seg isiɣzaf neɣ seg iɣbula i tettamneḍ."
          }
        },
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Тексерілмеген скрипттер қауіпсіздік пен құпиялылыққа қауіп төндіруі мүмкін. Тек сенетін кеңейтулерден немесе көздерден скрипттерді іске қосыңыз."
          }
        },
        "km": {
          "stringUnit": {
            "state": "translated",
            "value": "ស្គ្រីបដែលមិនបានផ្ទៀងផ្ទាត់អាចបង្កហានិភ័យសុវត្ថិភាព និងភាពឯកជន។ ដំណើរការស្គ្រីបពីផ្នែកបន្ថែម ឬប្រភពដែលអ្នកទុកចិត្តតែប៉ុណ្ណោះ។"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "확인되지 않은 스크립트는 보안 및 개인 정보 보호에 위험이 될 수 있습니다. 신뢰할 수 있는 확장 기능이나 출처의 스크립트만 실행하세요."
          }
        },
        "ku": {
          "stringUnit": {
            "state": "translated",
            "value": "Skrîptên nepesendkirî dikarin xetereyên ewlehî û nepenîtiyê derxînin holê. Tenê skrîptên bi niçik yan ji çavkaniyên ku hûn pê bawer in bidin xebitandin."
          }
        },
        "lo": {
          "stringUnit": {
            "state": "translated",
            "value": "ສະຄຣິບທີ່ບໍ່ໄດ້ຮັບການຢືນຢັນສາມາດສ້າງຄວາມສ່ຽງດ້ານຄວາມປອດໄພ ແລະ ຄວາມເປັນສ່ວນຕົວ. ແລ່ນສະຄຣິບຈາກສ່ວນຂະຫຍາຍ ຫຼື ແຫຼ່ງທີ່ທ່ານເຊື່ອຖືເທົ່ານັ້ນ."
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "പരിശോധിച്ചുറപ്പിക്കാത്ത സ്ക്രിപ്റ്റുകൾ സുരക്ഷയും സ്വകാര്യതയും അപകടസാധ്യതകൾ സൃഷ്ടിക്കും. നിങ്ങൾ വിശ്വസിക്കുന്ന വിപുലീകരണങ്ങളിൽ നിന്നോ ഉറവിടങ്ങളിൽ നിന്നോ മാത്രം സ്ക്രിപ്റ്റുകൾ പ്രവർത്തിപ്പിക്കുക."
          }
        },
        "nb-NO": {
          "stringUnit": {
            "state": "translated",
            "value": "Ubekreftede skript kan utgjøre sikkerhets- og personvernrisiko. Kjør kun skript fra utvidelser eller kilder du stoler på."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Niet-geverifieerde scripts kunnen beveiligings- en privacyrisico’s met zich meebrengen. Voer alleen scripts uit van extensies of bronnen die u vertrouwt."
          }
        },
        "nn-NO": {
          "stringUnit": {
            "state": "translated",
            "value": "Ikkje stadfesta skript kan utgjere sikkerheit- og personvernrisiko. Køyr berre skript frå utvidingar eller kjelder du stolar på."
          }
        },
        "oc": {
          "stringUnit": {
            "state": "translated",
            "value": "Los escripts non verificats pòdon comportar de risques de seguretat e de vida privada. Executatz solament los escripts que possedisson d’extensions o de fonts de fisança."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Niezweryfikowane skrypty mogą stwarzać zagrożenia bezpieczeństwa i prywatności. Uruchamiaj skrypty wyłącznie z rozszerzeń i innych źródeł, którym ufasz."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Scripts não verificados podem representar riscos de segurança e privacidade. Só execute scripts de extensões ou origens em que você confia."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Os scripts não verificados podem apresentar riscos de segurança e de privacidade. Apenas execute scripts de extensões ou fontes em que confia."
          }
        },
        "rm": {
          "stringUnit": {
            "state": "translated",
            "value": "Scripts betg verifitgads pon periclitar la segirezza e la protecziun da datas. Exequescha sulettamain scripts dad extensiuns u funtaunas da las qualas ti ta fidas."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Scripturile neverificate pot prezenta riscuri de securitate și confidențialitate. Rulează scripturi doar din extensii sau surse în care ai încredere."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Непроверенные скрипты могут представлять угрозу безопасности и конфиденциальности. Запускайте скрипты только из расширений или источников, которым вы доверяете."
          }
        },
        "sat": {
          "stringUnit": {
            "state": "translated",
            "value": "ᱵᱤᱱ ᱯᱩᱥᱴᱟᱹᱣ ᱟᱠᱟᱱ ᱥᱠᱨᱤᱯᱴ ᱨᱩᱠᱷᱤᱭᱟᱹ ᱟᱨ ᱜᱩᱱᱛᱷᱤ ᱨᱮᱭᱟᱜ ᱡᱷᱩᱠᱤ ᱛᱮᱭᱟᱨ ᱫᱟᱲᱮᱭᱟᱜᱼᱟ ᱾ ᱟᱢ ᱯᱟᱹᱛᱭᱟᱹᱣᱟᱱ ᱮᱠᱥᱴᱮᱱᱥᱚᱱ ᱥᱮ ᱥᱚᱨᱥ ᱠᱷᱚᱱ ᱥᱩᱢᱩᱝ ᱥᱠᱨᱤᱯᱴ ᱪᱟᱹᱞᱩᱭ ᱢᱮ ᱾"
          }
        },
        "sc": {
          "stringUnit": {
            "state": "translated",
            "value": "Is scripts non verificados podent cumportare un’arriscu de seguresa e de riservadesa. Esecuta isceti is scripts dae estensiones o mitzas fidadas."
          }
        },
        "scn": {
          "stringUnit": {
            "state": "translated",
            "value": "I prugrammi nun virificati ponnu èssiri un rìsicu pâ sicurizza e pâ privatizza. Abbìa sulu prugrammi di stinneri o funti chi ài fiducia."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Neoverené skripty môžu predstavovať riziká pre bezpečnosť a súkromie. Spúšťajte skripty iba z rozšírení alebo zdrojov, ktorým dôverujete."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nepreverjeni skripti lahko predstavljajo tveganje za varnost in zasebnost. Zaženite samo skripte razširitev ali virov, ki jim zaupate."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Programthet e paverifikuar mund të përbëjnë rreziqe sigurie dhe privatësie. Xhironi vetëm programthe nga zgjerime apo burime të cilëve u zini besë."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Непроверене скрипте могу бити ризик по сигурност и приватност. Покрените скрипте само из додатака или извора којима верујете."
          }
        },
        "sv-SE": {
          "stringUnit": {
            "state": "translated",
            "value": "Overifierade skript kan utgöra säkerhets- och integritetsrisker. Kör bara skript från tillägg eller källor som du litar på."
          }
        },
        "tg": {
          "stringUnit": {
            "state": "translated",
            "value": "Скриптҳои тасдиқнашуда метавонанд ба амният ва махфияти шумо ҳар гуна хатарҳоро ба вуҷуд оранд. Танҳо скриптҳоро аз васеъшавиҳо ё манбаъҳое, ки шумо ба он эътимод доред, иҷро кунед."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "สคริปต์ที่ไม่ได้ยืนยันสามารถก่อให้เกิดความเสี่ยงด้านความปลอดภัยและความเป็นส่วนตัวได้ ให้เรียกใช้สคริปต์จากส่วนขยายหรือแหล่งที่มาที่คุณเชื่อถือเท่านั้น"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Doğrulanmamış betikler güvenlik ve gizlilik riskleri doğurabilir. Yalnızca güvendiğiniz uzantılardan veya kaynaklardan gelen betikleri çalıştırın."
          }
        },
        "ug": {
          "stringUnit": {
            "state": "translated",
            "value": "دەلىللەنمىگەن قوليازما بىخەتەرلىك ۋە مەخپىيەتلىك خەۋپى ئېلىپ كېلىدۇ. پەقەت كېڭەيتىلمە ياكى ئىشەنچلىك مەنبەلەردىن كەلگەن قوليازمىنى ئىجرا قىلىڭ."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Неперевірені скрипти можуть становити загрозу безпеці та приватності. Запускайте скрипти лише з розширень або джерел, яким ви довіряєте."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Các tập lệnh chưa được xác minh có thể gây ra rủi ro về bảo mật và quyền riêng tư. Chỉ chạy tập lệnh từ tiện ích mở rộng hoặc nguồn mà bạn tin cậy."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未经验证的脚本可能带来安全和隐私风险。请确保只运行来自可信扩展或来源的脚本。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "未經驗證的指令碼，可能會造成安全性與隱私風險。請只執行來自可信的擴充套件或來源的指令碼。"
          }
        },
        "pa-Guru-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ਗ਼ੈਰ-ਤਸਦੀਕ ਕੀਤੀਆਂ ਸਕ੍ਰਿਪਟਾਂ ਸੁਰੱਖਿਆ ਅਤੇ ਪਰਦੇਦਾਰੀ ਖ਼ਤਰੇ ਹੁੰਦੀਆਂ ਹਨ। ਜਿਨ੍ਹਾਂ ਇਕਸਟੈਨਸ਼ਨਾਂ ਜਾਂ ਸਰੋਤਾਂ ਉੱਤੇ ਤੁਹਾਨੂੰ ਭਰੋਸਾ ਹੋਵੇ, ਉਹੀ ਸਕ੍ਰਿਪਟਾਂ ਨੂੰ ਚਲਾਓ।"
          }
        }
      }
    },
