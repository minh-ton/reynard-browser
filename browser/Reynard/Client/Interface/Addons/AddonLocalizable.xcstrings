          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "ഈ വിപുലീകരണം വിലക്കപ്പെട്ടതും പ്രവൎത്തനരഹിതവും ആണു്. താങ്ങൾക്കിതിനെ പ്രവൎത്തനക്ഷമമാക്കാൻ പറ്റും എന്നാൽ ഇതു് അപകടകരമായേക്കാം."
          }
        },
        "nb-NO": {
