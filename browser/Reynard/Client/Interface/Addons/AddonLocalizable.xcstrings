    "Clear recent browsing history, cookies, and related data": {
      "localizations": {
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "የቅርብ ጊዜ የአሰሳ ታሪክን፣ ኩኪዎችን እና ተዛማጅ መረጃዎችን ያጽዱ"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مسح تأريخ التصفح الحديث و ملفات تعريف الارتباط و البيانات المتعلقة بها"
          }
        },
        "ast": {
          "stringUnit": {
            "state": "translated",
            "value": "Llimpiar l'historial recién, les cookies y los datos rellacionaos"
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Son səyahət tarixçəsini, çərəzləri və bağlı məlumatları təmizləmək"
          }
        },
        "be": {
          "stringUnit": {
            "state": "translated",
            "value": "Выдаленне нядаўняй гісторыі аглядання, кукаў і звязаных з імі дадзеных"
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Изчистване на история, бисквитки и свързани данни"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "সাম্প্রতিক ব্রাউজিং ইতিহাস, কুকিজ, এবং এই সম্পর্কিত তথ্য মুছে ফেলুন"
          }
        },
        "br": {
          "stringUnit": {
            "state": "translated",
            "value": "Skarzhañ ar roll istor, an toupinoù hag ar roadennoù liammet nevesañ"
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Obriši skorašnju historiju surfanja, kolačiće, i srodne podatke"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Esborrar l’historial de navegació recent, les galetes i dades relacionades"
          }
        },
        "ceb": {
          "stringUnit": {
            "state": "translated",
            "value": "Panasa ang bag-ong browsing history, cookie, ug iglabot nga data"
          }
        },
        "ckb": {
          "stringUnit": {
            "state": "translated",
            "value": "کۆتا مێژووی کار، شەکرۆکە، و زانیاری وابەستە پاکبکەرەوە"
          }
        },
        "co": {
          "stringUnit": {
            "state": "translated",
            "value": "Squassà a cronolugia recente di navigazione, i canistrelli, è i dati assuciati"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Mazat nedávnou historii prohlížení, cookies a související data"
          }
        },
        "cy": {
          "stringUnit": {
            "state": "translated",
            "value": "Clirio’r hanes pori diweddar, cwcis a data cysylltiedig"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Rydde seneste browserhistorik, cookies og relaterede data"
          }
        },
        "de": {
