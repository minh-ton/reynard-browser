+  beginRegionSelection: "reynard-begin-region-selection.bin",
+  clipboardImage: "reynard-native-clipboard.png",
+});
+const CAPTURE_LIMITS = Object.freeze({
+  maximumPixels: 32 * 1024 * 1024,
+  maximumDimension: 32760,
+  minimumScale: 0.25,
+  maximumDurationMs: 120000,
+  tileTimeoutMs: 15000,
+});
+
+function calculateCaptureGeometry(
+  fullWidth,
+  fullHeight,
+  preferredScale,
+  limits = CAPTURE_LIMITS
+) {
+  if (
+    !Number.isFinite(fullWidth) ||
+    !Number.isFinite(fullHeight) ||
+    !Number.isFinite(preferredScale) ||
+    fullWidth <= 0 ||
+    fullHeight <= 0 ||
+    preferredScale <= 0
+  ) {
+    throw new RangeError("The page reported invalid capture dimensions");
+  }
+
+  const scale = Math.min(
+    preferredScale,
+    Math.sqrt(limits.maximumPixels / (fullWidth * fullHeight)),
+    limits.maximumDimension / fullWidth,
+    limits.maximumDimension / fullHeight
+  );
+  if (!Number.isFinite(scale) || scale < limits.minimumScale) {
+    throw new RangeError("This page is too large to capture safely");
+  }
+
+  const width = Math.floor(fullWidth * scale);
+  const height = Math.floor(fullHeight * scale);
+  if (
+    width < 1 ||
+    height < 1 ||
+    width > limits.maximumDimension ||
+    height > limits.maximumDimension ||
+    width * height > limits.maximumPixels
+  ) {
+    throw new RangeError("The capture exceeds Reynard's image safety limits");
+  }
+  return { width, height, scale };
+}
