+const EXTENSION_ID = "fullpage-capture@mosfor";
+const SUPPORTED_VERSION = "0.5.0";
+const NATIVE_MESSAGES = Object.freeze({
+  beginRegionSelection: "GeckoView:WebExtension:BeginRegionSelection",
+  clipboardImage: "GeckoView:WebExtension:ClipboardImage",
+});
