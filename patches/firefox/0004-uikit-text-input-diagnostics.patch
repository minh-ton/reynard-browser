 constexpr CGFloat kHandleHitRadius = 44.0;
 constexpr CGFloat kFallbackCharWidth = 8.0;
+constexpr CFTimeInterval kPendingKeyboardEditLifetime = 0.5;
+constexpr unsigned long long kReynardTextInputLogLimit = 1024 * 1024;
+NSString* const kReynardTextInputDiagnosticsKey =
+    @"ReynardTextInputDiagnosticsEnabled";
+NSString* const kReynardTextInputLogName = @"Reynard-TextInputDebug.log";
+
+static uint64_t sReynardTextInputSequence = 0;
+
+BOOL ReynardTextInputDiagnosticsEnabled() {
+  return [[NSUserDefaults standardUserDefaults]
+      boolForKey:kReynardTextInputDiagnosticsKey];
+}
+
+NSString* ReynardTextInputLogPath() {
+  NSArray<NSString*>* cachePaths = NSSearchPathForDirectoriesInDomains(
+      NSCachesDirectory, NSUserDomainMask, YES);
+  if (![cachePaths count]) {
+    return nil;
+  }
+  return [[cachePaths objectAtIndex:0]
+      stringByAppendingPathComponent:kReynardTextInputLogName];
+}
+
+void ReynardRemoveDisabledTextInputLog() {
+  if (ReynardTextInputDiagnosticsEnabled()) {
+    return;
+  }
+  NSString* path = ReynardTextInputLogPath();
+  if (path) {
+    [[NSFileManager defaultManager] removeItemAtPath:path error:nil];
+  }
+}
+
+NSString* ReynardTextInputRangeDescription(NSRange aRange) {
+  if (aRange.location == NSNotFound) {
+    return @"not-found";
+  }
+  return [NSString stringWithFormat:@"%lu:%lu",
+                                    static_cast<unsigned long>(aRange.location),
+                                    static_cast<unsigned long>(aRange.length)];
+}
+
+NSString* ReynardTextInputSanitize(NSString* aText, BOOL aSecure) {
+  if (aSecure) {
+    return @"<secure>";
+  }
+  NSString* text = aText ?: @"";
+  text = [text stringByReplacingOccurrencesOfString:@"\\" withString:@"\\\\"];
+  text = [text stringByReplacingOccurrencesOfString:@"\n" withString:@"\\n"];
+  text = [text stringByReplacingOccurrencesOfString:@"\r" withString:@"\\r"];
+  text = [text stringByReplacingOccurrencesOfString:@"|" withString:@"\\|"];
+  constexpr NSUInteger kMaximumLength = 256;
+  if ([text length] > kMaximumLength) {
+    text = [[text substringToIndex:kMaximumLength]
+        stringByAppendingString:@"..."];
+  }
+  return text;
+}
+
+void ReynardLogTextInputEvent(NSString* aEvent, NSString* aPhase,
+                              NSString* aInput, NSRange aArgumentRange,
+                              mozilla::widget::TextInputHandler* aHandler,
+                              BOOL aSecure) {
+  if (!ReynardTextInputDiagnosticsEnabled()) {
+    return;
+  }
+  @autoreleasepool {
+    NSRange selectedRange = NSMakeRange(NSNotFound, 0);
+    NSRange markedRange = NSMakeRange(NSNotFound, 0);
+    uint32_t textLength = 0;
+    nsString snapshot;
+    if (aHandler) {
+      aHandler->SelectedRange(selectedRange);
+      aHandler->MarkedRange(markedRange);
+      if (aHandler->TextLength(textLength) && textLength) {
+        aHandler->TextInRange(NSMakeRange(0, std::min(textLength, 256u)),
+                              snapshot);
+      }
+    }
+
+    NSString* snapshotText =
+        [NSString stringWithCharacters:
+                      reinterpret_cast<const unichar*>(snapshot.BeginReading())
+                                  length:snapshot.Length()];
+    NSString* line = [NSString
+        stringWithFormat:@"%.6f | %llu | %@.%@ | input=%@ | arg=%@ | "
+                         "selected=%@ | marked=%@ | length=%u | text=%@\n",
+                         [[NSDate date] timeIntervalSince1970],
+                         ++sReynardTextInputSequence, aEvent ?: @"unknown",
+                         aPhase ?: @"unknown",
+                         ReynardTextInputSanitize(aInput, aSecure),
+                         ReynardTextInputRangeDescription(aArgumentRange),
+                         ReynardTextInputRangeDescription(selectedRange),
+                         ReynardTextInputRangeDescription(markedRange), textLength,
+                         ReynardTextInputSanitize(snapshotText, aSecure)];
+
+    static dispatch_queue_t logQueue;
+    static dispatch_once_t onceToken;
+    dispatch_once(&onceToken, ^{
+      logQueue = dispatch_queue_create("com.minh-ton.Reynard.text-input-log",
+                                       DISPATCH_QUEUE_SERIAL);
+    });
+    dispatch_async(logQueue, ^{
+      @autoreleasepool {
+      NSString* path = ReynardTextInputLogPath();
+      if (!path) {
+        return;
+      }
+      NSFileManager* manager = [NSFileManager defaultManager];
+      NSDictionary* attributes = [manager attributesOfItemAtPath:path error:nil];
+      if ([attributes fileSize] > kReynardTextInputLogLimit) {
+        [manager removeItemAtPath:path error:nil];
+      }
+      if (![manager fileExistsAtPath:path]) {
+        [manager createFileAtPath:path contents:nil attributes:nil];
+      }
+      NSFileHandle* handle = [NSFileHandle fileHandleForWritingAtPath:path];
+      [handle seekToEndOfFile];
+      [handle writeData:[line dataUsingEncoding:NSUTF8StringEncoding]];
+      [handle closeFile];
+      }
+    });
+  }
+}

