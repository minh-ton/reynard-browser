+// Keeps rapid keyboard replacement commands coherent while Gecko's DOM
+// selection is still catching up to the preceding command.
+- (BOOL)pendingKeyboardEditSelection:(NSRange*)aSelection
+                             handler:(widget::TextInputHandler*)aHandler {
+  if (!aSelection || !aHandler ||
+      mEditable.mPendingKeyboardEditSelection.location == NSNotFound) {
+    return NO;
+  }
+
+  if (CFAbsoluteTimeGetCurrent() - mEditable.mPendingKeyboardEditTimestamp >
+      kPendingKeyboardEditLifetime) {
+    [self clearPendingKeyboardEditSelection];
+    return NO;
+  }
+
+  NSRange liveSelection = NSMakeRange(NSNotFound, 0);
+  if (!aHandler->SelectedRange(liveSelection)) {
+    [self clearPendingKeyboardEditSelection];
+    return NO;
+  }
+  if (mEditable.mPendingKeyboardEditGeneration !=
+          mEditable.mKeyboardEditGeneration ||
+      NSEqualRanges(liveSelection, mEditable.mPendingKeyboardEditSelection)) {
+    [self clearPendingKeyboardEditSelection];
+    return NO;
+  }
+  if (!NSEqualRanges(liveSelection,
+                     mEditable.mPendingKeyboardEditSourceSelection)) {
+    [self invalidatePendingKeyboardEditSelection];
+    return NO;
+  }
+
+  *aSelection = mEditable.mPendingKeyboardEditSelection;
+  return YES;
+}
+
+- (void)setPendingKeyboardEditSelection:(NSRange)aSelection
+                         sourceSelection:(NSRange)aSourceSelection {
+  mEditable.mKeyboardEditGeneration++;
+  mEditable.mPendingKeyboardEditSelection = aSelection;
+  mEditable.mPendingKeyboardEditSourceSelection = aSourceSelection;
+  mEditable.mPendingKeyboardEditTimestamp = CFAbsoluteTimeGetCurrent();
+  mEditable.mPendingKeyboardEditGeneration =
+      mEditable.mKeyboardEditGeneration;
+}
+
+- (void)clearPendingKeyboardEditSelection {
+  mEditable.mPendingKeyboardEditSelection = NSMakeRange(NSNotFound, 0);
+  mEditable.mPendingKeyboardEditSourceSelection = NSMakeRange(NSNotFound, 0);
+  mEditable.mPendingKeyboardEditTimestamp = 0;
+  mEditable.mPendingKeyboardEditGeneration = 0;
+}
+
+- (void)invalidatePendingKeyboardEditSelection {
+  mEditable.mKeyboardEditGeneration++;
+  [self clearPendingKeyboardEditSelection];
+}
