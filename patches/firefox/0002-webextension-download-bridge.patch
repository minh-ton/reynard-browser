+async function stageBlobDownload(url, filename, principal) {
+  let stagedFile;
+  try {
+    return await new Promise((resolve, reject) => {
+      NetUtil.asyncFetch(
+        {
+          uri: url,
+          loadingPrincipal: principal,
+          securityFlags:
+            Ci.nsILoadInfo.SEC_REQUIRE_SAME_ORIGIN_INHERITS_SEC_CONTEXT,
+          contentPolicyType: Ci.nsIContentPolicy.TYPE_OTHER,
+        },
+        (input, status, request) => {
+          if (!Components.isSuccessCode(status)) {
+            reject(Components.Exception("Unable to read blob download", status));
+            return;
+          }
+
+          let mimeType = "";
+          try {
+            mimeType = request.QueryInterface(Ci.nsIChannel).contentType;
+          } catch (_) {}
+
+          const requestedExtension = filename?.split(".").pop() ?? "";
+          const fileExtension = /^[a-z0-9]{1,10}$/i.test(requestedExtension)
+            ? requestedExtension.toLowerCase()
+            : "bin";
+          stagedFile = Services.dirsvc.get("TmpD", Ci.nsIFile);
+          stagedFile.append(`reynard-webextension.${fileExtension}`);
+          stagedFile.createUnique(Ci.nsIFile.NORMAL_FILE_TYPE, 0o600);
+
+          const output = Cc[
+            "@mozilla.org/network/file-output-stream;1"
+          ].createInstance(Ci.nsIFileOutputStream);
+          output.init(stagedFile, 0x02 | 0x08 | 0x20, 0o600, 0);
+          NetUtil.asyncCopy(input, output, copyStatus => {
+            if (!Components.isSuccessCode(copyStatus)) {
+              reject(
+                Components.Exception("Unable to stage blob download", copyStatus)
+              );
+              return;
+            }
+            resolve({ localFilePath: stagedFile.path, mimeType });
+          });
+        }
+      );
+    });
+  } catch (error) {
+    if (stagedFile?.exists()) {
+      stagedFile.remove(false);
+    }
+    throw error;
+  }
+}
