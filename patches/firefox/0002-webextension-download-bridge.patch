+function recordReynardDownload(event, details = "") {
+  try {
+    const file = Services.dirsvc.get("ProfD", Ci.nsIFile);
+    file.append("Reynard-DownloadDebug.log");
+    if (file.exists() && file.fileSize > 1024 * 1024) {
+      file.remove(false);
+    }
+    const stream = Cc["@mozilla.org/network/file-output-stream;1"].createInstance(
+      Ci.nsIFileOutputStream
+    );
+    stream.init(file, file.exists() ? 0x1a : 0x2a, 0o600, 0);
+    const converter = Cc[
+      "@mozilla.org/intl/converter-output-stream;1"
+    ].createInstance(Ci.nsIConverterOutputStream);
+    converter.init(stream, "UTF-8");
+    converter.writeString(`${new Date().toISOString()} | ${event} | ${details}\n`);
+    converter.close();
+  } catch (_) {}
+}

