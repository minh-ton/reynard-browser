 #include "nsOSHelperAppService.h"
+#include "nsMIMEInfoUIKit.h"
+#include "nsIPrincipal.h"
+#include "nsIURI.h"
+
+#import <UIKit/UIKit.h>
+
+bool ReynardOpenLinksInAppsEnabled() {
+  NSUserDefaults* defaults = [NSUserDefaults standardUserDefaults];
+  NSString* key = @"default.BrowsingSettings.openLinksInApps";
+  id storedValue = [defaults objectForKey:key];
+  return storedValue ? [defaults boolForKey:key] : true;
+}
+
+bool ReynardSupportsExternalScheme(const char* aScheme) {
+  if (!aScheme || !*aScheme) {
+    return false;
+  }
+  NSString* scheme = [[NSString stringWithUTF8String:aScheme] lowercaseString];
+  return [scheme isEqualToString:@"market"] ||
+         [scheme isEqualToString:@"reddit"];
+}

 nsOSHelperAppService::nsOSHelperAppService() : nsExternalHelperAppService() {}

