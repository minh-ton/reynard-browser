+
+    let destination;
+    try {
+      destination = Services.io.newURI(link.href);
+    } catch (e) {
+      return;
+    }
+    if (destination.scheme !== "http" && destination.scheme !== "https") {
+      return;
+    }
+
+    this.sendAsyncMessage("GeckoView:LinkActivated", {
+      uri: destination.displaySpec,
+      triggerUri: this.contentWindow.document.documentURI,
+      defaultPrevented: event.defaultPrevented,
+    });
+  }
