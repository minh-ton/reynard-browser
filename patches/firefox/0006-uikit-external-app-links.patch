+      aEvent.altKey ||
+      aEvent.ctrlKey ||
+      aEvent.metaKey ||
+      aEvent.shiftKey
+    ) {
+      return;
+    }
+
+    const link = aEvent
+      .composedPath()
+      .find(node => node?.localName === "a" && typeof node.href === "string");
