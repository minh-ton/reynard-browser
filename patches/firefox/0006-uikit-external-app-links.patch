+}
+
+NS_IMETHODIMP
+nsOSHelperAppService::SetProtocolHandlerDefaults(nsIHandlerInfo* aHandlerInfo,
+                                                 bool aOSHandlerExists) {
+  NS_ENSURE_ARG_POINTER(aHandlerInfo);
+  aHandlerInfo->SetPreferredAction(aOSHandlerExists
+                                       ? nsIHandlerInfo::useSystemDefault
+                                       : nsIHandlerInfo::alwaysAsk);
+  aHandlerInfo->SetAlwaysAskBeforeHandling(false);
+  return NS_OK;
+}
+
+NS_IMETHODIMP
+nsOSHelperAppService::LoadURI(nsIURI* aURI, nsIPrincipal* aTriggeringPrincipal,
+                              nsIPrincipal* aRedirectPrincipal,
+                              mozilla::dom::BrowsingContext* aBrowsingContext,
+                              bool aWasTriggeredExternally,
+                              bool aHasValidUserGestureActivation,
+                              bool aNewWindowTarget) {
+  mozilla::AssertIsOnMainThread();
+  NS_ENSURE_ARG_POINTER(aURI);
+  NS_ENSURE_ARG_POINTER(aBrowsingContext);
+
+  if (ExternalProtocolIsBlockedBySandbox(aBrowsingContext,
+                                         aHasValidUserGestureActivation)) {
+    return NS_OK;
+  }
+  if (!aWasTriggeredExternally && !aHasValidUserGestureActivation) {
+    return NS_OK;
+  }
+
+  nsCOMPtr<nsIURI> escapedURI;
+  nsresult rv = EscapeURI(aURI, getter_AddRefs(escapedURI));
+  NS_ENSURE_SUCCESS(rv, rv);
+
+  nsCOMPtr<nsIWidget> widget =
+      aBrowsingContext->Canonical()->GetParentProcessWidgetContaining();
+  NS_ENSURE_TRUE(widget, NS_ERROR_ABORT);
+
+  RefPtr<nsWindow> window = nsWindow::From(widget);
+  NS_ENSURE_TRUE(window && !window->Destroyed(), NS_ERROR_ABORT);
+
+  RefPtr<mozilla::widget::EventDispatcher> dispatcher =
+      window->GetEventDispatcher();
+  NS_ENSURE_TRUE(dispatcher, NS_ERROR_ABORT);
+
+  static constexpr auto kExternalProtocolEvent =
+      u"GeckoView:ExternalProtocol"_ns;
+  NS_ENSURE_TRUE(dispatcher->HasEmbedderListener(kExternalProtocolEvent),
+                 NS_ERROR_ABORT);
+
+  mozilla::dom::AutoJSAPI jsapi;
+  NS_ENSURE_TRUE(jsapi.Init(xpc::PrivilegedJunkScope()), NS_ERROR_FAILURE);
+  JSContext* cx = jsapi.cx();
+  JS::RootedObject payload(cx, JS_NewPlainObject(cx));
+  NS_ENSURE_TRUE(payload, NS_ERROR_OUT_OF_MEMORY);
+
+  nsAutoCString spec;
+  rv = escapedURI->GetSpec(spec);
+  NS_ENSURE_SUCCESS(rv, rv);
+  NS_ENSURE_TRUE(DefineStringProperty(cx, payload, "uri", spec),
+                 NS_ERROR_FAILURE);
+
+  nsCOMPtr<nsIURI> triggerURI;
+  if (aTriggeringPrincipal) {
+    aTriggeringPrincipal->GetURI(getter_AddRefs(triggerURI));
+  }
+  if (triggerURI) {
+    nsAutoCString triggerSpec;
+    if (NS_SUCCEEDED(triggerURI->GetSpec(triggerSpec))) {
+      NS_ENSURE_TRUE(
+          DefineStringProperty(cx, payload, "triggerUri", triggerSpec),
+          NS_ERROR_FAILURE);
+    }
+  }
+  NS_ENSURE_TRUE(
+      JS_DefineProperty(cx, payload, "hasUserGesture",
+                        aHasValidUserGestureActivation, JSPROP_ENUMERATE),
+      NS_ERROR_FAILURE);
+
+  JS::RootedValue payloadValue(cx, JS::ObjectValue(*payload));
+  return dispatcher->DispatchToEmbedder(cx, kExternalProtocolEvent,
+                                        payloadValue, nullptr);
 }
