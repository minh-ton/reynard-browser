+  NS_ENSURE_TRUE(handler, NS_ERROR_OUT_OF_MEMORY);
+  handler->SetPreferredAction(nsIHandlerInfo::useSystemDefault);
+  handler->SetAlwaysAskBeforeHandling(false);
+  NS_ADDREF(*_retval = handler);
+  return NS_OK;
+}
+
+NS_IMETHODIMP
+nsOSHelperAppService::SetProtocolHandlerDefaults(nsIHandlerInfo* aHandlerInfo,
+                                                 bool aOSHandlerExists) {
+  NS_ENSURE_ARG_POINTER(aHandlerInfo);
+  aHandlerInfo->SetPreferredAction(
+      aOSHandlerExists ? nsIHandlerInfo::useSystemDefault
+                       : nsIHandlerInfo::alwaysAsk);
+  aHandlerInfo->SetAlwaysAskBeforeHandling(false);
+  return NS_OK;
+}
+
+NS_IMETHODIMP
+nsOSHelperAppService::LoadURI(
+    nsIURI* aURI, nsIPrincipal* aTriggeringPrincipal,
+    nsIPrincipal* aRedirectPrincipal,
+    mozilla::dom::BrowsingContext* aBrowsingContext,
+    bool aWasTriggeredExternally, bool aHasValidUserGestureActivation,
+    bool aNewWindowTarget) {
+  NS_ENSURE_ARG_POINTER(aURI);
+
+  if (ExternalProtocolIsBlockedBySandbox(aBrowsingContext,
+                                         aHasValidUserGestureActivation)) {
+    return NS_OK;
+  }
+  if (!aWasTriggeredExternally && !aHasValidUserGestureActivation) {
+    return NS_OK;
+  }
+  if (!ReynardOpenLinksInAppsEnabled()) {
+    return NS_OK;
+  }
+
+  nsCOMPtr<nsIURI> escapedURI;
+  nsresult rv = EscapeURI(aURI, getter_AddRefs(escapedURI));
+  NS_ENSURE_SUCCESS(rv, rv);
+
+  nsAutoCString spec;
+  escapedURI->GetSpec(spec);
+  NSString* requestedValue = [NSString stringWithUTF8String:spec.get()];
+  NSString* launchValue = requestedValue;
+  BOOL universalLinkOnly = NO;
+
+  nsAutoCString scheme;
+  escapedURI->GetScheme(scheme);
+  if (!ReynardSupportsExternalScheme(scheme.get())) {
+    return NS_ERROR_NOT_AVAILABLE;
+  }
+  const BOOL isRedditMarketFallback =
+      scheme.EqualsLiteral("market") &&
+      spec.Find("com.reddit.frontpage") != kNotFound;
+  if (isRedditMarketFallback) {
+    nsCOMPtr<nsIURI> sourceURI;
+    if (aTriggeringPrincipal) {
+      aTriggeringPrincipal->GetURI(getter_AddRefs(sourceURI));
+    }
+    if (sourceURI) {
+      nsAutoCString sourceSpec;
+      sourceURI->GetSpec(sourceSpec);
+      launchValue = [NSString stringWithUTF8String:sourceSpec.get()];
+      universalLinkOnly = YES;
+    } else {
+      launchValue = @"reddit://";
+    }
+  }
+
+  NSURL* launchURL = launchValue ? [NSURL URLWithString:launchValue] : nil;
+  if (!launchURL) {
+    return NS_ERROR_MALFORMED_URI;
+  }
+
+  dispatch_async(dispatch_get_main_queue(), ^{
+    NSDictionary<UIApplicationOpenExternalURLOptionsKey, id>* options =
+        universalLinkOnly
+            ? @{UIApplicationOpenURLOptionUniversalLinksOnly : @YES}
+            : @{};
+    [[UIApplication sharedApplication]
+                  openURL:launchURL
+                  options:options
+        completionHandler:^(BOOL opened) {
+          if (!opened && isRedditMarketFallback) {
+            NSURL* fallbackURL = [NSURL URLWithString:@"reddit://"];
+            [[UIApplication sharedApplication]
+                          openURL:fallbackURL
+                          options:@{}
+                completionHandler:nil];
+          }
+        }];
+  });
+  return NS_OK;
 }
