+      return;
+    }
+
+    this.sendAsyncMessage("Reynard:OnTrustedLinkClick", {
+      requestId: Services.uuid.generateUUID().toString(),
+      uri: uri.displaySpec,
+      triggerUri:
+        this.contentWindow.document.documentURIObject?.displaySpec ?? null,
+    });
+  }
+
