@@ -51,7 +82,102 @@ NS_IMETHODIMP
 nsOSHelperAppService::GetProtocolHandlerInfoFromOS(const nsACString& aScheme,
                                                    bool* found,
                                                    nsIHandlerInfo** _retval) {
-  // We don't want to get protocol handlers from the OS in GV; the app
