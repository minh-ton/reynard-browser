+- (void)setupModernTextInput {
+  [self setupWebSelectionGestures];
+
+  if (Class selectionDisplayInteractionClass =
+          NSClassFromString(@"UITextSelectionDisplayInteraction")) {
+    id selectionDisplayInteraction =
+        [[selectionDisplayInteractionClass alloc] initWithTextInput:self
+                                                           delegate:self];
+    mEditable.mSelectionDisplayInteraction =
+        [selectionDisplayInteraction retain];
+    [self addInteraction:mEditable.mSelectionDisplayInteraction];
+
+    mEditable.mSelectionHandlePanRecognizer = [[UIPanGestureRecognizer alloc]
+        initWithTarget:self
+                action:@selector(panSelectionHandle:)];
+    mEditable.mSelectionHandlePanRecognizer.delegate = self;
+    mEditable.mSelectionHandlePanRecognizer.maximumNumberOfTouches = 1;
+    mEditable.mSelectionHandlePanRecognizer.cancelsTouchesInView = YES;
+    [self addGestureRecognizer:mEditable.mSelectionHandlePanRecognizer];
+  }
+}
