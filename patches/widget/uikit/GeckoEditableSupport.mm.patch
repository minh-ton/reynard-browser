+// Queries Gecko for the current selection range.
+bool TextInputHandler::SelectedRange(NSRange& aRange) {
+  aRange = NSMakeRange(NSNotFound, 0);
+
+  if (mSelectedRangeOverride.isSome()) {
+    aRange = *mSelectedRangeOverride;
+    return true;
+  }
+
+  if (Destroyed()) {
+    return false;
+  }
+
+  WidgetQueryContentEvent query(true, eQuerySelectedText, mWidget);
+  query.InitForQuerySelectedText(SelectionType::eNormal);
+  mWidget->DispatchWindowEvent(query);
+  if (query.DidNotFindSelection()) {
+    return false;
+  }
+
+  const uint32_t offset = query.mReply->StartOffset();
+  const uint32_t length = query.mReply->DataRef().Length();
+  aRange = NSMakeRange(offset, length);
+  return true;
+}
+
+bool TextInputHandler::MarkedRange(NSRange& aRange) {
+  aRange = HasMarkedText() ? mMarkedRange : NSMakeRange(NSNotFound, 0);
+  return HasMarkedText();
+}
+
+// Updates Gecko's selection range.
+bool TextInputHandler::SetSelectedRange(const NSRange& aRange) {
+  if (Destroyed() || aRange.location == NSNotFound) {
+    return false;
+  }
+
+  if (aRange.location > UINT32_MAX || aRange.length > UINT32_MAX) {
+    return false;
+  }
+
+  WidgetSelectionEvent event(true, eSetSelection, mWidget);
+  event.mOffset = static_cast<uint32_t>(aRange.location);
+  event.mLength = static_cast<uint32_t>(aRange.length);
+  event.mExpandToClusterBoundary = false;
+  mWidget->DispatchWindowEvent(event);
+  return event.mSucceeded;
+}
+
+// Returns the full editable text length.
+bool TextInputHandler::TextLength(uint32_t& aLength) {
+  aLength = 0;
+  nsString text;
+  if (!TextInRange(NSMakeRange(0, UINT32_MAX), text)) {
+    return false;
+  }
+  aLength = text.Length();
+  return true;
+}
+
+// Reads Gecko text for a document range.
+bool TextInputHandler::TextInRange(const NSRange& aRange, nsString& aText) {
+  aText.Truncate();
+
+  if (Destroyed() || aRange.location == NSNotFound) {
+    return false;
+  }
+
+  if (HasMarkedText() && aRange.location >= mMarkedRange.location &&
+      aRange.length <= mMarkedRange.length) {
+    const NSUInteger relativeStart = aRange.location - mMarkedRange.location;
+    if (relativeStart <= mMarkedRange.length - aRange.length) {
+      aText.Assign(Substring(mMarkedText, relativeStart, aRange.length));
+      return true;
+    }
+  }
+
+  if (aRange.location > UINT32_MAX || aRange.length > UINT32_MAX) {
+    return false;
+  }
+
+  WidgetQueryContentEvent query(true, eQueryTextContent, mWidget);
+  query.InitForQueryTextContent(static_cast<uint32_t>(aRange.location),
+                                static_cast<uint32_t>(aRange.length));
+  mWidget->DispatchWindowEvent(query);
+  if (query.Failed()) {
+    return false;
+  }
+
+  aText = query.mReply->DataRef();
+  return true;
+}
+
+// Replaces Gecko text inside a document range.
+bool TextInputHandler::ReplaceRange(const NSRange& aRange, NSString* aText) {
+  if (Destroyed() || aRange.location == NSNotFound) {
+    return false;
+  }
+
+  if (!SetSelectedRange(aRange)) {
+    return false;
+  }
+
+  nsString replacement;
+  CopyNSStringToXPCOMString(aText ?: @"", replacement);
+
+  if (replacement.IsEmpty()) {
+    return RunCommand(eContentCommandDelete, false);
+  }
+
+  WidgetContentCommandEvent event(true, eContentCommandInsertText, mWidget);
+  event.mString = Some(replacement);
+  mWidget->DispatchWindowEvent(event);
+  return event.mSucceeded;
+}
+
+// Queries Gecko for the rect covering a document range.
+bool TextInputHandler::TextRectForRange(const NSRange& aRange,
+                                        LayoutDeviceIntRect& aRect) {
+  if (Destroyed() || aRange.location == NSNotFound) {
+    return false;
+  }
+
+  if (aRange.length == 0) {
+    return CaretRectForOffset(aRange.location, aRect);
+  }
+
+  if (aRange.location > UINT32_MAX || aRange.length > UINT32_MAX) {
+    return false;
+  }
+
+  WidgetQueryContentEvent query(true, eQueryTextRect, mWidget);
+  query.InitForQueryTextRect(static_cast<uint32_t>(aRange.location),
+                             static_cast<uint32_t>(aRange.length));
+  mWidget->DispatchWindowEvent(query);
+  if (query.Failed()) {
+    return false;
+  }
+
+  aRect = query.mReply->mRect;
+  return true;
+}
+
+// Queries Gecko for the caret rect at a document offset.
+bool TextInputHandler::CaretRectForOffset(uint32_t aOffset,
+                                          LayoutDeviceIntRect& aRect) {
+  if (Destroyed()) {
+    return false;
+  }
+
+  WidgetQueryContentEvent query(true, eQueryCaretRect, mWidget);
+  query.InitForQueryCaretRect(aOffset);
+  mWidget->DispatchWindowEvent(query);
+  if (query.Failed()) {
+    return false;
+  }
+
+  aRect = query.mReply->mRect;
+  return true;
+}
+
+// Queries Gecko for the editable region rect.
+bool TextInputHandler::EditorRect(LayoutDeviceIntRect& aRect) {
+  if (Destroyed()) {
+    return false;
+  }
+
+  WidgetQueryContentEvent query(true, eQueryEditorRect, mWidget);
+  mWidget->DispatchWindowEvent(query);
+  if (query.Failed() || !query.mReply->mIsEditableContent) {
+    return false;
+  }
+
+  aRect = query.mReply->mRect;
+  return true;
+}
+
+// Runs a Gecko content command.
+bool TextInputHandler::RunCommand(EventMessage aMessage, bool aOnlyEnabledCheck,
+                                  bool* aIsEnabled) {
+  if (Destroyed()) {
+    if (aIsEnabled) {
+      *aIsEnabled = false;
+    }
+    return false;
+  }
+
+  WidgetContentCommandEvent event(true, aMessage, mWidget, aOnlyEnabledCheck);
+  mWidget->DispatchWindowEvent(event);
+  if (aIsEnabled) {
+    *aIsEnabled = event.mIsEnabled;
+  }
+  return event.mSucceeded;
+}
