+- (void)teardownModernTextInput {
+  [self teardownWebSelectionGestures];
+
+  if ([(id)mEditable.mSelectionDisplayInteraction view] == self) {
+    [self removeInteraction:mEditable.mSelectionDisplayInteraction];
+  }
+  [mEditable.mSelectionDisplayInteraction release];
+  mEditable.mSelectionDisplayInteraction = nil;
+  if (mEditable.mSelectionHandlePanRecognizer) {
+    [self removeGestureRecognizer:mEditable.mSelectionHandlePanRecognizer];
+  }
+  [mEditable.mSelectionHandlePanRecognizer release];
+  mEditable.mSelectionHandlePanRecognizer = nil;
+}
+
+- (void)updateModernTextInteractions {
+  if (!mEditable.mEditableTextInteraction ||
+      !mEditable.mNonEditableTextInteraction) {
+    return;
+  }
+
+  const bool keyboardDisabled =
+      mGeckoChild && mGeckoChild->IsVirtualKeyboardDisabled();
+  const BOOL shouldAttachNonEditableInteraction = keyboardDisabled;
+  if (keyboardDisabled) {
+    if (mEditable.mEditableTextInteraction.view == self) {
+      [self removeInteraction:mEditable.mEditableTextInteraction];
+    }
+    if (shouldAttachNonEditableInteraction &&
+        mEditable.mNonEditableTextInteraction.view != self) {
+      [self addInteraction:mEditable.mNonEditableTextInteraction];
+    } else if (!shouldAttachNonEditableInteraction &&
+               mEditable.mNonEditableTextInteraction.view == self) {
+      [self removeInteraction:mEditable.mNonEditableTextInteraction];
+    }
+  } else {
+    if (mEditable.mNonEditableTextInteraction.view == self) {
+      [self removeInteraction:mEditable.mNonEditableTextInteraction];
+    }
+    if (mEditable.mEditableTextInteraction.view != self) {
+      [self addInteraction:mEditable.mEditableTextInteraction];
+    }
+  }
+
+  [self updateSelectionActivation];
+}
+
+// Keep iOS 17+ selection display active whenever the editable view
+// owns first responder, even when Gecko changes selection outside UIKit's
+// built-in text gestures.
+- (void)updateSelectionActivation {
+  if (mEditable.mSelectionDisplayInteraction == nil) {
+    return;
+  }
+
+  const BOOL shouldActivate =
+      mGeckoChild && !mGeckoChild->Destroyed() && [self isFirstResponder];
+  const BOOL isActivated =
+      [(id)mEditable.mSelectionDisplayInteraction isActivated];
+  if (isActivated != shouldActivate) {
+    [(id)mEditable.mSelectionDisplayInteraction setActivated:shouldActivate];
+  }
+}
+
+// This is mostly just for hiding the handles when they're offscreen, like when
+// the view is zoomed in and user just drag the view while a selection is active
+// and then the handle become outside of the visible area.
+- (void)updateHandleVisibility {
+  if (mEditable.mSelectionDisplayInteraction == nil) {
+    return;
+  }
+
+  const BOOL hasAttachedTextInteraction =
+      mEditable.mEditableTextInteraction.view == self ||
+      mEditable.mNonEditableTextInteraction.view == self;
+  CGRect visibleBounds = [self selectionBounds];
+  widget::TextInputHandler* handler = [self textHandler];
+  NSRange selectedRange = [self selectedRange];
+  BOOL startEndpointVisible = NO;
+  BOOL endEndpointVisible = NO;
+  if (handler && selectedRange.location != NSNotFound &&
+      selectedRange.length > 0) {
+    const EndpointRects visibleEndpoints =
+        [self visibleHandleRectsForRange:selectedRange handler:handler];
+    startEndpointVisible = visibleEndpoints.hasStart;
+    endEndpointVisible = visibleEndpoints.hasEnd;
+  }
+  NSArray* handleViews =
+      [(id)mEditable.mSelectionDisplayInteraction handleViews];
+  NSUInteger handleIndex = 0;
+  for (UIView* handleView in handleViews) {
+    BOOL shouldHide =
+        hasAttachedTextInteraction && mEditable.mTextInteractionInProgress;
+    if (!shouldHide) {
+      if (selectedRange.location != NSNotFound && selectedRange.length > 0 &&
+          [handleViews count] >= 2) {
+        // UIKit exposes the handle views as an ordered pair, so map index 0/1
+        // to Gecko's start/end endpoint visibility before doing final clipping.
+        if (handleIndex == 0) {
+          shouldHide = !startEndpointVisible;
+        } else if (handleIndex == 1) {
+          shouldHide = !endEndpointVisible;
+        }
+      }
+
+      // Trust Gecko's endpoint visibility over the UIKit handle view's
+      // frame, which includes decorative chrome (teardrop) that may be out
+      // past the editor bounds at line edges (and therefore make the entire
+      // handle hidden although it is supposed to be visible).
+      const BOOL geckoEndpointIsVisible =
+          (handleIndex == 0 && startEndpointVisible) ||
+          (handleIndex == 1 && endEndpointVisible);
+
+      if (!shouldHide && !geckoEndpointIsVisible) {
+        CGRect handleRect = [self convertRect:handleView.bounds
+                                     fromView:handleView];
+        shouldHide = CGRectIsEmpty(visibleBounds) ||
+                     CGRectIsNull(visibleBounds) ||
+                     !CGRectContainsRect(CGRectStandardize(visibleBounds),
+                                         CGRectStandardize(handleRect));
+      }
+    }
+    handleView.hidden = shouldHide;
+    handleIndex++;
+  }
+}
+
+- (void)refreshSelectionUI {
+  if (mEditable.mSelectionDisplayInteraction == nil) {
+    return;
+  }
+
+  [self updateSelectionActivation];
+  if ([(id)mEditable.mSelectionDisplayInteraction isActivated]) {
+    [(id)mEditable.mSelectionDisplayInteraction setNeedsSelectionUpdate];
+  }
+  [NSObject
+      cancelPreviousPerformRequestsWithTarget:self
+                                     selector:@selector(updateHandleVisibility)
+                                       object:nil];
+  [self performSelector:@selector(updateHandleVisibility)
+             withObject:nil
+             afterDelay:0
+                inModes:@[ NSRunLoopCommonModes ]];
+  [self updateHandleVisibility];
+}
+
+- (BOOL)gestureRecognizerShouldBegin:(UIGestureRecognizer*)aGestureRecognizer {
+  if (aGestureRecognizer == mEditable.mWebSelectionLongPressRecognizer) {
+    if ([self isUsingWebTextSelection]) {
+      return ![self hasActiveWebSelection];
+    }
+    return NO;
+  }
+
+  if (aGestureRecognizer == mEditable.mWebSelectionDismissTapRecognizer) {
+    if ([self isUsingWebTextSelection]) {
+      return [self hasActiveWebSelection];
+    }
+    return NO;
+  }
+
+  if (aGestureRecognizer != mEditable.mSelectionHandlePanRecognizer) {
+    return YES;
+  }
+
+  if (mEditable.mSelectionDisplayInteraction == nil ||
+      !mEditable.mSelectionHandlePanRecognizer) {
+    return NO;
+  }
+
+  widget::TextInputHandler* handler = [self textHandler];
+  if (!handler) {
+    return NO;
+  }
+
+  NSRange range = [self selectedRange];
+  if (range.location == NSNotFound || range.length == 0) {
+    return NO;
+  }
+
+  CGPoint point = [mEditable.mSelectionHandlePanRecognizer locationInView:self];
+  GeckoSelectionHandle handle = [self closestHandleToPoint:point
+                                                     range:range
+                                                   handler:handler];
+  return handle != GeckoSelectionHandleNone;
+}
+
+- (BOOL)gestureRecognizer:(UIGestureRecognizer*)aGestureRecognizer
+       shouldReceiveTouch:(UITouch*)aTouch {
+  if (aGestureRecognizer == mEditable.mWebSelectionDismissTapRecognizer) {
+    return [self shouldDismissWebSelectionAtPoint:[aTouch locationInView:self]];
+  }
+
+  return YES;
+}
+
+// Drive visible selection-handle drags on iOS 17+ when the passive
+// selection display interaction is showing the system handles but does not own
+// the drag gesture.
+- (void)panSelectionHandle:(UIPanGestureRecognizer*)aRecognizer {
+  if (mEditable.mSelectionDisplayInteraction == nil ||
+      aRecognizer != mEditable.mSelectionHandlePanRecognizer) {
+    return;
+  }
+
+  widget::TextInputHandler* handler = [self textHandler];
+  if (!handler) {
+    return;
+  }
+
+  CGPoint point = [aRecognizer locationInView:self];
+  switch (aRecognizer.state) {
+    case UIGestureRecognizerStateBegan: {
+      NSRange range = [self selectedRange];
+      [self startHandleTrackingAtPoint:point range:range handler:handler];
+      if (mEditable.mActiveSelectionHandle == GeckoSelectionHandleNone) {
+        return;
+      }
+
+      mEditable.mTextInteractionInProgress = YES;
+      [self becomeFirstResponder];
+      [self refreshSelectionUI];
+      break;
+    }
+    case UIGestureRecognizerStateChanged: {
+      if (mEditable.mActiveSelectionHandle == GeckoSelectionHandleNone ||
+          mEditable.mSelectionHandleAnchorOffset == NSNotFound) {
+        return;
+      }
+
+      // Translate the finger position into a predicted endpoint, then rebuild
+      // the dragged selection range against the fixed anchor offset.
+      ChildViewTextPosition* position =
+          [self textPosForPosition:[self closestPositionToPoint:point]];
+      if (!position) {
+        return;
+      }
+
+      NSUInteger anchorOffset =
+          [self clampOffset:mEditable.mSelectionHandleAnchorOffset];
+      ChildViewTextPosition* anchorPosition =
+          [ChildViewTextPosition positionWithOffset:anchorOffset];
+      ChildViewTextRange* draggedRange =
+          mEditable.mActiveSelectionHandle == GeckoSelectionHandleStart
+              ? [ChildViewTextRange rangeWithStart:position end:anchorPosition]
+              : [ChildViewTextRange rangeWithStart:anchorPosition end:position];
+      [self setSelectedTextRange:draggedRange];
+      [self refreshSelectionUI];
+      break;
+    }
+    case UIGestureRecognizerStateCancelled:
+    case UIGestureRecognizerStateEnded:
+    case UIGestureRecognizerStateFailed: {
+      if (mEditable.mActiveSelectionHandle == GeckoSelectionHandleNone) {
+        return;
+      }
+
+      mEditable.mTextInteractionInProgress = NO;
+      [self refreshSelectionUI];
+      [self resetHandleState];
+      [self updateEditMenu];
+      break;
+    }
+    default:
+      break;
+  }
+}
+
+@end
+
+// MARK: - ChildView (Legacy)
+
+@implementation ChildView (Legacy)
+
+- (void)refreshLegacySelectionViews {
+  if (mEditable.mSelectionDisplayInteraction != nil || !self.window) {
+    return;
+  }
+
+  NSMutableArray<UIView*>* selectionViews = [NSMutableArray array];
+  CollectViewsOfClass(self.window, @"UITextSelectionView", selectionViews);
+  for (UIView* selectionView in selectionViews) {
+    selectionView.hidden = NO;
+    CallSelector(selectionView, @"activate");
+    CallSelector(selectionView, @"selectionChanged");
+    CallSelector(selectionView, @"updateRangeViewForSelectionMode");
+    CallSelector(selectionView, @"updateSelectionRects");
+    CallSelector(selectionView, @"updateSelectionRectsIfNeeded");
+    CallSelector(selectionView, @"updateSelectionDots");
+    CallSelector(selectionView, @"updateSelectionCommands");
+
+    UIView* rangeView =
+        (UIView*)CallSelector(selectionView, @"rangeView", (id)nil);
+    if ([rangeView isKindOfClass:[UIView class]]) {
+      rangeView.hidden = NO;
+      [rangeView setNeedsDisplay];
+      [rangeView setNeedsLayout];
+      [rangeView layoutIfNeeded];
+    }
+
+    [selectionView setNeedsDisplay];
+    [selectionView setNeedsLayout];
+    [selectionView layoutIfNeeded];
+  }
+}
+
+- (void)deactivateLegacySelectionViews {
+  if (mEditable.mSelectionDisplayInteraction != nil || !self.window) {
+    return;
+  }
+
+  NSMutableArray<UIView*>* selectionViews = [NSMutableArray array];
+  CollectViewsOfClass(self.window, @"UITextSelectionView", selectionViews);
+  for (UIView* selectionView in selectionViews) {
+    CallSelector(selectionView, @"deactivate");
+    CallSelector(selectionView, @"updateRangeViewForSelectionMode");
+    CallSelector(selectionView, @"updateSelectionRectsIfNeeded");
+    CallSelector(selectionView, @"updateSelectionCommands");
+
+    UIView* rangeView =
+        (UIView*)CallSelector(selectionView, @"rangeView", (id)nil);
+    if ([rangeView isKindOfClass:[UIView class]]) {
+      rangeView.hidden = YES;
+      [rangeView setNeedsDisplay];
+      [rangeView setNeedsLayout];
+      [rangeView layoutIfNeeded];
+    }
+
+    selectionView.hidden = YES;
+    [selectionView setNeedsDisplay];
+    [selectionView setNeedsLayout];
+    [selectionView layoutIfNeeded];
+  }
+}
+
+- (void)configureLegacyNonEditableTextInteractionGestures {
+  if (!mEditable.mNonEditableTextInteraction) {
+    return;
+  }
+
+  for (UIGestureRecognizer* gesture in mEditable.mNonEditableTextInteraction
+           .gesturesForFailureRequirements) {
+    gesture.delaysTouchesBegan = NO;
+    gesture.delaysTouchesEnded = NO;
+  }
+}
+
+- (void)updateLegacyTextInteractions {
+  if (!mEditable.mEditableTextInteraction ||
+      !mEditable.mNonEditableTextInteraction) {
+    return;
+  }
+
+  const bool keyboardDisabled =
+      mGeckoChild && mGeckoChild->IsVirtualKeyboardDisabled();
+  const BOOL shouldAttachNonEditableInteraction = keyboardDisabled;
+
+  if (keyboardDisabled) {
+    if (mEditable.mEditableTextInteraction.view == self) {
+      [self removeInteraction:mEditable.mEditableTextInteraction];
+    }
+    if (shouldAttachNonEditableInteraction &&
+        mEditable.mNonEditableTextInteraction.view != self) {
+      [self addInteraction:mEditable.mNonEditableTextInteraction];
+    } else if (!shouldAttachNonEditableInteraction &&
+               mEditable.mNonEditableTextInteraction.view == self) {
+      [self removeInteraction:mEditable.mNonEditableTextInteraction];
+    }
+    if (shouldAttachNonEditableInteraction) {
+      [self configureLegacyNonEditableTextInteractionGestures];
+    }
+  } else {
+    if (mEditable.mNonEditableTextInteraction.view == self) {
+      [self removeInteraction:mEditable.mNonEditableTextInteraction];
+    }
+    if (mEditable.mEditableTextInteraction.view != self) {
+      [self addInteraction:mEditable.mEditableTextInteraction];
+    }
+  }
+}
+
+// Older iOS keeps private selection grabbers alive at the clipped
+// viewport edge, so hide edge-snapped grabbers when the corresponding Gecko
+// endpoint is actually offscreen.
+- (void)updateLegacyGrabbers {
+  if (mEditable.mSelectionDisplayInteraction != nil || !self.window) {
+    return;
+  }
+
+  if (mEditable.mTextInteractionInProgress) {
+    [self setLegacyGrabbersHidden:NO];
+    return;
+  }
+
+  UITextRange* selectedTextRange = [self selectedTextRange];
+  if (!selectedTextRange || [selectedTextRange isEmpty]) {
+    return;
+  }
+
+  CGRect visibleBounds = [self selectionBounds];
+  if (CGRectIsEmpty(visibleBounds) || CGRectIsNull(visibleBounds)) {
+    return;
+  }
+
+  CGRect visibleBoundsInWindow = [self convertRect:visibleBounds
+                                            toView:self.window];
+  BOOL containsStart = NO;
+  BOOL containsEnd = NO;
+
+  // Marks which endpoints are genuinely visible after clipping
+  for (UITextSelectionRect* selectionRect in
+       [self selectionRectsForRange:selectedTextRange]) {
+    containsStart = containsStart || selectionRect.containsStart;
+    containsEnd = containsEnd || selectionRect.containsEnd;
+  }
+
+  NSMutableArray<UIView*>* grabberViews = [NSMutableArray array];
+  CollectViewsOfClass(self.window, @"UISelectionGrabber", grabberViews);
+
+  const CGFloat edgeTolerance = 6.0;
+  for (UIView* grabberView in grabberViews) {
+    CGRect grabberRect = [grabberView convertRect:grabberView.bounds
+                                           toView:self.window];
+    // Legacy grabbers often pin themselves to the viewport edge when the real
+    // endpoint scrolls offscreen. Detect that snapped position and hide only
+    // the endpoint whose selection rects said it is no longer actually visible.
+    const BOOL nearLeftEdge =
+        fabs(CGRectGetMinX(grabberRect) -
+             CGRectGetMinX(visibleBoundsInWindow)) <= edgeTolerance;
+    const BOOL nearRightEdge =
+        fabs(CGRectGetMaxX(grabberRect) -
+             CGRectGetMaxX(visibleBoundsInWindow)) <= edgeTolerance;
+    const BOOL nearTopEdge =
+        fabs(CGRectGetMinY(grabberRect) -
+             CGRectGetMinY(visibleBoundsInWindow)) <= edgeTolerance;
+    const BOOL nearBottomEdge =
+        fabs(CGRectGetMaxY(grabberRect) -
+             CGRectGetMaxY(visibleBoundsInWindow)) <= edgeTolerance;
+
+    BOOL shouldHide = NO;
+    if (!containsStart && (nearLeftEdge || nearTopEdge)) {
+      shouldHide = YES;
+    }
+    if (!containsEnd && (nearRightEdge || nearBottomEdge)) {
+      shouldHide = YES;
+    }
+    grabberView.hidden = shouldHide;
+  }
+}
+
+- (void)setLegacyGrabbersHidden:(BOOL)aHidden {
+  if (mEditable.mSelectionDisplayInteraction != nil || !self.window) {
+    return;
+  }
+
+  NSMutableArray<UIView*>* grabberViews = [NSMutableArray array];
+  CollectViewsOfClass(self.window, @"UISelectionGrabber", grabberViews);
+  for (UIView* grabberView in grabberViews) {
+    grabberView.hidden = aHidden;
+  }
+}
+
+@end
+
+// MARK: - ChildView (WebSelection)
+
+@implementation ChildView (WebSelection)
+
+- (BOOL)isUsingWebTextSelection {
+  return mGeckoChild && !mGeckoChild->Destroyed() &&
+         mGeckoChild->IsVirtualKeyboardDisabled();
+}
+
+- (BOOL)hasActiveWebSelection {
+  if (![self isUsingWebTextSelection]) {
+    return NO;
+  }
+
+  NSRange selectedRange = [self selectedRange];
+  return selectedRange.location != NSNotFound && selectedRange.length > 0;
+}
+
+- (void)activateWebSelectionIfNeeded {
+  if (![self hasActiveWebSelection] || [self isFirstResponder]) {
+    return;
+  }
+
+  [self becomeFirstResponder];
+}
+
+- (void)setupWebSelectionGestures {
+  if (mEditable.mWebSelectionLongPressRecognizer) {
+    return;
+  }
+
+  mEditable.mWebSelectionLongPressRecognizer =
+      [[UILongPressGestureRecognizer alloc]
+          initWithTarget:self
+                  action:@selector(handleWebSelectionLongPress:)];
+  mEditable.mWebSelectionLongPressRecognizer.delegate = self;
+  mEditable.mWebSelectionLongPressRecognizer.cancelsTouchesInView = YES;
+  [self addGestureRecognizer:mEditable.mWebSelectionLongPressRecognizer];
+
+  mEditable.mWebSelectionDismissTapRecognizer = [[UITapGestureRecognizer alloc]
+      initWithTarget:self
+              action:@selector(handleWebSelectionDismissTap:)];
+  mEditable.mWebSelectionDismissTapRecognizer.delegate = self;
+  mEditable.mWebSelectionDismissTapRecognizer.cancelsTouchesInView = YES;
+  [self addGestureRecognizer:mEditable.mWebSelectionDismissTapRecognizer];
+}
+
+- (void)teardownWebSelectionGestures {
+  if (mEditable.mWebSelectionLongPressRecognizer) {
+    [self removeGestureRecognizer:mEditable.mWebSelectionLongPressRecognizer];
+    [mEditable.mWebSelectionLongPressRecognizer release];
+    mEditable.mWebSelectionLongPressRecognizer = nil;
+  }
+
+  if (mEditable.mWebSelectionDismissTapRecognizer) {
+    [self removeGestureRecognizer:mEditable.mWebSelectionDismissTapRecognizer];
+    [mEditable.mWebSelectionDismissTapRecognizer release];
+    mEditable.mWebSelectionDismissTapRecognizer = nil;
+  }
+}
+
+- (void)handleWebSelectionLongPress:(UILongPressGestureRecognizer*)aRecognizer {
+  if (aRecognizer.state != UIGestureRecognizerStateBegan ||
+      ![self isUsingWebTextSelection] || [self hasActiveWebSelection]) {
+    return;
+  }
+
+  [self selectWebWordAtPoint:[aRecognizer locationInView:self]];
+}
+
+- (BOOL)shouldDismissWebSelectionAtPoint:(CGPoint)aPoint {
+  if (![self hasActiveWebSelection]) {
+    return NO;
+  }
+
+  widget::TextInputHandler* handler = [self textHandler];
+  if (!handler) {
+    return NO;
+  }
+
+  NSRange selectedRange = [self selectedRange];
+  if (selectedRange.location == NSNotFound || selectedRange.length == 0) {
+    return NO;
+  }
+
+  CGRect handleRect = CGRectZero;
+  if ([self visibleHandleRect:&handleRect
+                     atOffset:selectedRange.location
+                       handle:GeckoSelectionHandleStart
+                      handler:handler] &&
+      // Keep a generous hit target around the native handles so a near-miss
+      // while aiming for drag/reposition still counts as an interaction with
+      // the current selection instead of dismissing it.
+      CGRectContainsPoint(CGRectInset(handleRect, -22.0, -22.0), aPoint)) {
+    return NO;
+  }
+
+  const NSUInteger endOffset = selectedRange.location + selectedRange.length;
+  if ([self visibleHandleRect:&handleRect
+                     atOffset:endOffset
+                       handle:GeckoSelectionHandleEnd
+                      handler:handler] &&
+      // Match the same larger safety margin for the trailing handle so the
+      // dismiss tap recognizer does not steal touches intended for handle
+      // drags at the edge of the selection.
+      CGRectContainsPoint(CGRectInset(handleRect, -22.0, -22.0), aPoint)) {
+    return NO;
+  }
+
+  UITextRange* textRange = [self textRangeForRange:selectedRange];
+  for (UITextSelectionRect* rect in
+       [self webSelectionRectsForRange:textRange]) {
+    // Use a smaller padding around the highlight itself so taps visually on
+    // the selected glyphs still count as interacting with the selection,
+    // while nearby page taps can dismiss it predictably.
+    if (CGRectContainsPoint(CGRectInset(rect.rect, -8.0, -8.0), aPoint)) {
+      return NO;
+    }
+  }
+
+  return YES;
+}
+
+- (void)handleWebSelectionDismissTap:(UITapGestureRecognizer*)aRecognizer {
+  if (aRecognizer.state != UIGestureRecognizerStateRecognized ||
+      ![self hasActiveWebSelection]) {
+    return;
+  }
+
+  const CGPoint point = [aRecognizer locationInView:self];
+  if (![self shouldDismissWebSelectionAtPoint:point]) {
+    return;
+  }
+
+  [self clearWebSelection];
+}
+
+- (BOOL)clearWebSelection {
+  if (![self isUsingWebTextSelection] || !mGeckoChild ||
+      mGeckoChild->Destroyed()) {
+    return NO;
+  }
+
+  dom::BrowserParent* browserParent = dom::BrowserParent::GetFocused();
+  if (!browserParent) {
+    return NO;
+  }
+
+  nsCOMPtr<nsIWidget> widget = browserParent->GetTextInputHandlingWidget();
+  if (widget != mGeckoChild) {
+    return NO;
+  }
+
+  bool didClear = false;
+  if (!browserParent->SendClearSelection(&didClear) || !didClear) {
+    return NO;
+  }
+
+  [self selectionGeometryChanged];
+
+  [self resetHandleState];
+  [self scheduleResponderBlur];
+  return YES;
+}
+
+- (BOOL)setWebSelectedRange:(NSRange)aRange {
+  if (![self isUsingWebTextSelection] || !mGeckoChild ||
+      mGeckoChild->Destroyed() || aRange.location == NSNotFound ||
+      aRange.location > UINT32_MAX || aRange.length > UINT32_MAX) {
+    return NO;
+  }
+
+  dom::BrowserParent* browserParent = dom::BrowserParent::GetFocused();
+  if (!browserParent) {
+    return NO;
+  }
+
+  nsCOMPtr<nsIWidget> widget = browserParent->GetTextInputHandlingWidget();
+  if (widget != mGeckoChild) {
+    return NO;
+  }
+
+  bool didSet = false;
+  return browserParent->SendSetSelectionRange(
+             static_cast<uint32_t>(aRange.location),
+             static_cast<uint32_t>(aRange.length), &didSet) &&
+         didSet;
+}
+
+- (BOOL)selectWebWordAtPoint:(CGPoint)aPoint {
+  if (![self isUsingWebTextSelection] || !mGeckoChild ||
+      mGeckoChild->Destroyed()) {
+    return NO;
+  }
+
+  if (![self isFirstResponder] && ![self becomeFirstResponder]) {
+    return NO;
+  }
+
+  dom::BrowserParent* browserParent = dom::BrowserParent::GetFocused();
+  if (!browserParent) {
+    return NO;
+  }
+
+  nsCOMPtr<nsIWidget> widget = browserParent->GetTextInputHandlingWidget();
+  if (widget != mGeckoChild) {
+    return NO;
+  }
+
+  const CGFloat scale = [self contentScaleFactor];
+  const LayoutDeviceIntPoint parentPoint(
+      static_cast<int32_t>(std::lround(aPoint.x * scale)),
+      static_cast<int32_t>(std::lround(aPoint.y * scale)));
+  const LayoutDeviceIntPoint childPoint =
+      browserParent->TransformParentToChild(parentPoint);
+  bool didSelect = false;
+  if (!browserParent->SendSelectWordAtPoint(childPoint, &didSelect) ||
+      !didSelect) {
+    return NO;
+  }
+
+  [self selectionGeometryChanged];
+
+  return YES;
+}
+
+- (BOOL)queryWebTextRects:(CopyableTArray<LayoutDeviceIntRect>&)aRects
+                  inRange:(NSRange)aRange {
+  aRects.Clear();
+  const uint64_t endOffset = static_cast<uint64_t>(aRange.location) +
+                             static_cast<uint64_t>(aRange.length);
+
+  if (![self isUsingWebTextSelection] || !mGeckoChild ||
+      mGeckoChild->Destroyed() || aRange.location == NSNotFound ||
+      aRange.length == 0 || aRange.location > UINT32_MAX ||
+      aRange.length > UINT32_MAX ||
+      endOffset > static_cast<uint64_t>(UINT32_MAX) + 1u) {
+    return NO;
+  }
+
+  aRects.SetCapacity(aRange.length);
+  for (NSUInteger index = 0; index < aRange.length; index++) {
+    LayoutDeviceIntRect rect;
+    if (![self queryWebTextRect:rect atOffset:aRange.location + index]) {
+      rect.SetEmpty();
+    }
+    aRects.AppendElement(rect);
+  }
+
+  return YES;
+}
+
+- (BOOL)queryWebTextRect:(LayoutDeviceIntRect&)aRect
+                atOffset:(NSUInteger)aOffset {
+  aRect.SetEmpty();
+
+  if (![self isUsingWebTextSelection] || !mGeckoChild ||
+      mGeckoChild->Destroyed() || aOffset > UINT32_MAX) {
+    return NO;
+  }
+
+  WidgetQueryContentEvent query(true, eQueryTextRect, mGeckoChild);
+  query.InitForQueryTextRect(static_cast<uint32_t>(aOffset), 1);
+  mGeckoChild->DispatchWindowEvent(query);
+  if (query.Failed()) {
+    return NO;
+  }
+
+  aRect = query.mReply->mRect;
+  return YES;
+}
+
+- (BOOL)queryWebCaretRect:(LayoutDeviceIntRect&)aRect
+                 atOffset:(NSUInteger)aOffset {
+  aRect.SetEmpty();
+
+  if (![self isUsingWebTextSelection] || !mGeckoChild ||
+      mGeckoChild->Destroyed() || aOffset > UINT32_MAX) {
+    return NO;
+  }
+
+  dom::BrowserParent* browserParent = dom::BrowserParent::GetFocused();
+  if (!browserParent) {
+    return NO;
+  }
+
+  nsCOMPtr<nsIWidget> widget = browserParent->GetTextInputHandlingWidget();
+  if (widget != mGeckoChild) {
+    return NO;
+  }
+
+  bool didQuery = false;
+  if (!browserParent->SendQueryCaretRectAtOffset(static_cast<uint32_t>(aOffset),
+                                                 &didQuery, &aRect) ||
+      !didQuery) {
+    return NO;
+  }
+
+  return YES;
+}
+
+- (BOOL)webCaretRect:(CGRect*)aRect atOffset:(NSUInteger)aOffset {
+  if (!aRect) {
+    return NO;
+  }
+
+  LayoutDeviceIntRect rect;
+  if (![self queryWebCaretRect:rect atOffset:aOffset]) {
+    *aRect = CGRectZero;
+    return NO;
+  }
+
+  *aRect = DevPixelsToUIKitPoints(rect, [self contentScaleFactor]);
+  aRect->size.width = 2.0;
+  return YES;
+}
+
+- (NSArray*)webSelectionRectsForRange:(UITextRange*)aRange {
+  NSRange queryRange = [self rangeForTextRange:aRange];
+  if (queryRange.location == NSNotFound || queryRange.length == 0) {
+    return [NSArray array];
+  }
+
+  widget::TextInputHandler* handler = [self textHandler];
+  if (!handler) {
+    return [NSArray array];
+  }
+
+  CGRect visibleBounds = [self selectionBounds];
+  if (CGRectIsEmpty(visibleBounds) || CGRectIsNull(visibleBounds)) {
+    return [NSArray array];
+  }
+
+  CopyableTArray<LayoutDeviceIntRect> rects;
+  if (![self queryWebTextRects:rects inRange:queryRange]) {
+    return [NSArray array];
+  }
+
+  const NSUInteger startOffset = queryRange.location;
+  const NSUInteger endOffset = queryRange.location + queryRange.length;
+
+  CGRect endpointRect = CGRectZero;
+  BOOL containsStart = [self visibleHandleRect:&endpointRect
+                                      atOffset:startOffset
+                                        handle:GeckoSelectionHandleStart
+                                       handler:handler];
+  BOOL containsEnd = [self visibleHandleRect:&endpointRect
+                                    atOffset:endOffset
+                                      handle:GeckoSelectionHandleEnd
+                                     handler:handler];
+
+  NSMutableArray* selectionRects = [NSMutableArray array];
+  CGRect currentRect = CGRectZero;
+  BOOL hasCurrentRect = NO;
+
+  auto appendCurrentRect = [&]() {
+    if (!hasCurrentRect) {
+      return;
+    }
+    AppendSelectionRect(selectionRects, currentRect, NO, NO);
+    currentRect = CGRectZero;
+    hasCurrentRect = NO;
+  };
+
+  for (const LayoutDeviceIntRect& rect : rects) {
+    if (rect.IsEmpty()) {
+      appendCurrentRect();
+      continue;
+    }
+
+    CGRect uiRect = DevPixelsToUIKitPoints(rect, [self contentScaleFactor]);
+    CGRect clippedRect = uiRect;
+    if (!ClipCGRectToBounds(clippedRect, visibleBounds)) {
+      appendCurrentRect();
+      continue;
+    }
+
+    if (!hasCurrentRect) {
+      currentRect = clippedRect;
+      hasCurrentRect = YES;
+      continue;
+    }
+
+    if (!RectsShareVisualLine(currentRect, clippedRect)) {
+      appendCurrentRect();
+      currentRect = clippedRect;
+      hasCurrentRect = YES;
+      continue;
+    }
+
+    currentRect = UnionSelectionFragments(currentRect, clippedRect);
+  }
+
+  appendCurrentRect();
+
+  if ([selectionRects count] == 0) {
+    return selectionRects;
+  }
+
+  ChildViewTextSelectionRect* firstRect = [selectionRects objectAtIndex:0];
+  firstRect.containsStartValue = containsStart;
+  ChildViewTextSelectionRect* lastRect = [selectionRects lastObject];
+  lastRect.containsEndValue = containsEnd;
+  return selectionRects;
+}
+
+- (CGRect)webFirstRectForRange:(UITextRange*)aRange {
+  NSArray* selectionRects = [self webSelectionRectsForRange:aRange];
+  if ([selectionRects count] == 0) {
+    return CGRectZero;
+  }
+
+  return [(UITextSelectionRect*)[selectionRects objectAtIndex:0] rect];
+}
+
+- (BOOL)webCanPerformAction:(SEL)aAction {
+  widget::TextInputHandler* handler = [self textHandler];
+  if (!handler) {
+    return NO;
+  }
+
+  NSRange selection = NSMakeRange(NSNotFound, 0);
+  handler->SelectedRange(selection);
+  const BOOL hasSelection =
+      selection.location != NSNotFound && selection.length > 0;
+
+  if (aAction == @selector(copy:)) {
+    return hasSelection;
+  }
+
+  return NO;
+}
+
+- (void)performWebCopy:(id)aSender {
+  (void)aSender;
+  if (widget::TextInputHandler* handler = [self textHandler]) {
+    handler->RunCommand(eContentCommandCopy, false);
+  }
+}
+
+@end
