+- (BOOL)hasText {
+  if (!mGeckoChild || mGeckoChild->Destroyed()) {
+    return NO;
+  }
+
+  if ([self isUsingWebTextSelection]) {
+    widget::TextInputHandler* handler = [self textHandler];
+    uint32_t length = 0;
+    const BOOL hasLength = handler && handler->TextLength(length);
+    if (hasLength) {
+      return length > 0;
+    }
+
+    NSRange range = [self selectedRange];
+    return range.location != NSNotFound && range.length > 0;
+  }
+
+  widget::InputContext context = mGeckoChild->GetInputContext();
+  if (context.mIMEState.mEnabled == IMEEnabled::Disabled) {
+    return NO;
+  }
+  return YES;
+}
