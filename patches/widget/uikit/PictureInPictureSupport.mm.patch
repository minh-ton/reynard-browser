+#include "PictureInPictureSupport.h"
+
+#import <AVFoundation/AVFoundation.h>
+
+#include <utility>
+
+#include "mozilla/layers/NativeLayerCA.h"
+#include "mozilla/widget/EventDispatcher.h"
+#include "nsWindow.h"
+
+using namespace mozilla;
+using namespace mozilla::layers;
+using namespace mozilla::widget;
+
+namespace mozilla::widget {
+
+void InstallPictureInPictureSourceObserver(nsWindow* aWindow) {
+  NativeLayerRoot* nativeLayerRoot = aWindow->GetNativeLayerRoot();
+  NativeLayerRootCA* root =
+      nativeLayerRoot ? nativeLayerRoot->AsNativeLayerRootCA() : nullptr;
+  EventDispatcher* eventDispatcher = aWindow->GetEventDispatcher();
+  if (!root || !eventDispatcher) {
+    return;
+  }
+  RefPtr<EventDispatcher> dispatcher = eventDispatcher;
+  root->SetPictureInPictureSourceChangedCallback(
+      [dispatcher = std::move(dispatcher)]() {
+        dispatcher->DispatchToEmbedder(
+            u"GeckoView:PictureInPicture:SourceChanged"_ns);
+      });
+}
+
+AVSampleBufferDisplayLayer* GetPictureInPictureDisplayLayer(nsWindow* aWindow) {
+  if (!aWindow) {
+    return nil;
+  }
+  NativeLayerRoot* nativeLayerRoot = aWindow->GetNativeLayerRoot();
+  NativeLayerRootCA* root =
+      nativeLayerRoot ? nativeLayerRoot->AsNativeLayerRootCA() : nullptr;
+  if (!root) {
+    return nil;
+  }
+  return [(AVSampleBufferDisplayLayer*)root->CopyPictureInPictureSource()
+      autorelease];
+}
+
+}  // namespace mozilla::widget
