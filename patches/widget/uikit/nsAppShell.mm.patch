+static void NotifyObserverTopic(const char* aTopic,
+                                const char16_t* aData = nullptr) {
+  if (nsCOMPtr<nsIObserverService> observerService =
+          services::GetObserverService()) {
+    observerService->NotifyObservers(nullptr, aTopic, aData);
+  }
+}
+
+static const char16_t* ThermalStateData(NSProcessInfoThermalState aState) {
+  switch (aState) {
+    case NSProcessInfoThermalStateNominal:
+      return u"nominal";
+    case NSProcessInfoThermalStateFair:
+      return u"fair";
+    case NSProcessInfoThermalStateSerious:
+      return u"serious";
+    case NSProcessInfoThermalStateCritical:
+      return u"critical";
+  }
+
+  MOZ_CRASH("Unexpected NSProcessInfoThermalState");
+}
+
+static void HandleMemoryPressure(
+    dispatch_source_memorypressure_flags_t aPressureFlags) {
+  MOZ_ASSERT(NS_IsMainThread());
+
+  IOSMemoryPressureLevel pressureLevel;
+  switch (aPressureFlags) {
+    case DISPATCH_MEMORYPRESSURE_NORMAL:
+      pressureLevel = IOSMemoryPressureLevel::Value::eNormal;
+      break;
+    case DISPATCH_MEMORYPRESSURE_WARN:
+      pressureLevel = IOSMemoryPressureLevel::Value::eWarning;
+      break;
+    case DISPATCH_MEMORYPRESSURE_CRITICAL:
+      pressureLevel = IOSMemoryPressureLevel::Value::eCritical;
+      break;
+    default:
+      pressureLevel = IOSMemoryPressureLevel::Value::eUnexpected;
+      break;
+  }
+
+  RefPtr<nsAvailableMemoryWatcherBase> watcher =
+      nsAvailableMemoryWatcherBase::GetSingleton();
+  watcher->OnMemoryPressureChanged(pressureLevel);
+}
 
