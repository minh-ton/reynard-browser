+
+- (void)thermalStateDidChange:(NSNotification*)notification {
+  if (![NSThread isMainThread]) {
+    dispatch_async(dispatch_get_main_queue(), ^{
+      [self thermalStateDidChange:nil];
+    });
+    return;
+  }
+
+  NSProcessInfoThermalState newThermalState =
+      [NSProcessInfo processInfo].thermalState;
+  if (mThermalState == newThermalState) {
+    return;
+  }
+
+  mThermalState = newThermalState;
+  NotifyObserverTopic("system-thermal-state-changed",
+                      ThermalStateData(mThermalState));
+}
+
+- (void)powerStateDidChange:(NSNotification*)notification {
+  if (![NSThread isMainThread]) {
+    dispatch_async(dispatch_get_main_queue(), ^{
+      [self powerStateDidChange:nil];
+    });
+    return;
+  }
+
+  BOOL isLowPowerModeEnabled = [NSProcessInfo processInfo].lowPowerModeEnabled;
+  if (mIsLowPowerModeEnabled == isLowPowerModeEnabled) {
+    return;
+  }
+
+  mIsLowPowerModeEnabled = isLowPowerModeEnabled;
+  NotifyObserverTopic("system-power-state-changed",
+                      mIsLowPowerModeEnabled ? u"low-power" : u"normal");
+}
+
+- (void)handleForegroundTransition:(BOOL)isForeground {
+  if (mHasForegroundState && mIsForeground == isForeground) {
+    return;
+  }
+
+  mIsForeground = isForeground;
+  mHasForegroundState = YES;
+
+  if (isForeground) {
+    if (!sDidSendInitialForeground) {
+      NotifyObserverTopic("geckoview-initial-foreground");
+      sDidSendInitialForeground = true;
+    }
+    NotifyObserverTopic("application-foreground");
+  } else {
+    NotifyObserverTopic("application-background");
+    NotifyObserverTopic("memory-pressure", u"heap-minimize");
+  }
+}
+
+- (void)handleActiveTransition:(BOOL)isActive {
+  if (mHasActiveState && mIsActive == isActive) {
+    return;
+  }
+
+  mIsActive = isActive;
+  mHasActiveState = YES;
+  NotifyObserverTopic(isActive ? "application-active" : "application-inactive");
 }
 @end
 
