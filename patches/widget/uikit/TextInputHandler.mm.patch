+bool TextInputHandler::SetMarkedText(NSString* aText,
+                                     const NSRange& aSelectedRange) {
+  if (Destroyed()) {
+    return false;
+  }
+
+  nsString text;
+  CopyNSStringToXPCOMString(aText ?: @"", text);
+  const NSRange selectedRange =
+      ClampCompositionSelectionRange(aSelectedRange, text.Length());
+  mMarkedText = text;
+
+  nsEventStatus status = nsEventStatus_eIgnore;
+  nsresult rv = mDispatcher->BeginNativeInputTransaction();
+  if (NS_FAILED(rv)) {
+    return false;
+  }
+
+  if (!HasMarkedText()) {
+    NSRange selection = NSMakeRange(NSNotFound, 0);
+    if (!SelectedRange(selection) || selection.location == NSNotFound) {
+      return false;
+    }
+
+    mMarkedRange = NSMakeRange(selection.location, 0);
+    mSelectedRangeOverride = Some(selection);
+    rv = mDispatcher->StartComposition(status, nullptr);
+    if (NS_FAILED(rv) || Destroyed()) {
+      ClearCompositionState();
+      return false;
+    }
+  }
+
+  mMarkedRange.length = text.Length();
+  mSelectedRangeOverride = Some(NSMakeRange(
+      mMarkedRange.location + selectedRange.location, selectedRange.length));
+
+  if (text.IsEmpty()) {
+    rv = mDispatcher->CommitComposition(status, &text, nullptr);
+    ClearCompositionState();
+    return NS_SUCCEEDED(rv) && !Destroyed();
+  }
+
+  RefPtr<TextRangeArray> ranges =
+      CreateTextRangeArrayForMarkedText(text.Length(), selectedRange);
+  rv = mDispatcher->SetPendingComposition(text, ranges);
+  if (NS_FAILED(rv)) {
+    return false;
+  }
+
+  rv = mDispatcher->FlushPendingComposition(status, nullptr);
+  return NS_SUCCEEDED(rv) && !Destroyed();
+}
+
+bool TextInputHandler::UnmarkText() {
+  if (Destroyed() || !HasMarkedText()) {
+    return false;
+  }
+
+  nsEventStatus status = nsEventStatus_eIgnore;
+  nsresult rv = mDispatcher->BeginNativeInputTransaction();
+  if (NS_FAILED(rv)) {
+    return false;
+  }
+
+  rv = mDispatcher->CommitComposition(status, nullptr, nullptr);
+  ClearCompositionState();
+  return NS_SUCCEEDED(rv) && !Destroyed();
+}
+
+bool TextInputHandler::CancelMarkedText() {
+  if (Destroyed() || !HasMarkedText()) {
+    return false;
+  }
+
+  nsString empty;
+  nsEventStatus status = nsEventStatus_eIgnore;
+  nsresult rv = mDispatcher->BeginNativeInputTransaction();
+  if (NS_FAILED(rv)) {
+    return false;
+  }
+
+  rv = mDispatcher->CommitComposition(status, &empty, nullptr);
+  ClearCompositionState();
+  return NS_SUCCEEDED(rv) && !Destroyed();
+}
