+static NSRange ClampCompositionSelectionRange(const NSRange& aSelectedRange,
+                                              NSUInteger aTextLength) {
+  const NSUInteger location = std::min(aSelectedRange.location, aTextLength);
+  const NSUInteger length =
+      std::min(aSelectedRange.length, aTextLength - location);
+  return NSMakeRange(location, length);
+}
+
+static already_AddRefed<TextRangeArray> CreateTextRangeArrayForMarkedText(
+    NSUInteger aTextLength, const NSRange& aSelectedRange) {
+  RefPtr<TextRangeArray> ranges = new TextRangeArray();
+  if (!aTextLength) {
+    return ranges.forget();
+  }
+
+  const NSRange selectedRange =
+      ClampCompositionSelectionRange(aSelectedRange, aTextLength);
+  const uint32_t selectedStart = static_cast<uint32_t>(selectedRange.location);
+  const uint32_t selectedEnd = static_cast<uint32_t>(NSMaxRange(selectedRange));
+  const uint32_t textLength = static_cast<uint32_t>(aTextLength);
+
+  if (selectedStart > 0) {
+    TextRange rawPrefix;
+    rawPrefix.mStartOffset = 0;
+    rawPrefix.mEndOffset = selectedStart;
+    rawPrefix.mRangeType = TextRangeType::eRawClause;
+    ranges->AppendElement(rawPrefix);
+  }
+
+  if (selectedEnd > selectedStart) {
+    TextRange selectedRawClause;
+    selectedRawClause.mStartOffset = selectedStart;
+    selectedRawClause.mEndOffset = selectedEnd;
+    selectedRawClause.mRangeType = TextRangeType::eSelectedRawClause;
+    ranges->AppendElement(selectedRawClause);
+  }
+
+  if (selectedEnd < textLength) {
+    TextRange rawSuffix;
+    rawSuffix.mStartOffset = selectedEnd;
+    rawSuffix.mEndOffset = textLength;
+    rawSuffix.mRangeType = TextRangeType::eRawClause;
+    ranges->AppendElement(rawSuffix);
+  }
+
+  TextRange caret;
+  caret.mStartOffset = selectedEnd;
+  caret.mEndOffset = selectedEnd;
+  caret.mRangeType = TextRangeType::eCaret;
+  ranges->AppendElement(caret);
+  return ranges.forget();
+}
