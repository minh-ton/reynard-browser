   } else {
     mCompositionStart.reset();
     mTextRectArray.reset();
+
+    // REYNARD: Cache character rects for a neighborhood around a non-collapsed
+    // selection so the parent process can detect visual line boundaries during
+    // handle dragging.
+    static bool sInLineRectCache = false;
+    if (!sInLineRectCache && mSelection.isSome() && mSelection->mHasRange &&
+        !mSelection->IsCollapsed() && mText.isSome() && mText->Length() > 0) {
+      sInLineRectCache = true;
+      const uint32_t textLength = mText->Length();
+      const uint32_t selStart = std::min(mSelection->StartOffset(), textLength);
+      const uint32_t selEnd = std::min(mSelection->EndOffset(), textLength);
+      if (selStart < selEnd) {
+        // Derive padding from the widget width so the cache always covers at
+        // least one full visual line regardless of screen size or orientation.
+        // Narrowest char is ~4 points with 17px, so we use width * 0.25.
+        // However, user may set smaller font, so we just extend a little
+        // bit more to width * 0.3
+        LayoutDeviceIntRect widgetBounds = aWidget->GetBounds();
+        const uint32_t kPad =
+            widgetBounds.Width() > 0
+                ? static_cast<uint32_t>(widgetBounds.Width() * 0.3) + 1
+                : 300;
+        const uint32_t cacheStart = selStart > kPad ? selStart - kPad : 0;
+        const uint32_t cacheEnd = std::min(selEnd + kPad, textLength);
+        const uint32_t cacheLength = cacheEnd - cacheStart;
+        if (cacheLength > 0) {
+          RectArray rects;
+          if (QueryCharRectArray(aWidget, cacheStart, cacheLength, rects) &&
+              rects.Length() > 0) {
+            mTextRectArray = Some(TextRectArray(cacheStart));
+            mTextRectArray->mRects = std::move(rects);
+          }
+        }
+
+        const uint32_t selLength = selEnd - selStart;
+        if (mTextRectArray.isNothing() ||
+            !mTextRectArray->IsRangeCompletelyInRange(selStart, selLength)) {
+          RectArray selRect;
+          if (!(QueryCharRectArray(aWidget, selStart, selLength, selRect) &&
+                selRect.Length() == selLength)) {
+            selRect.Clear();
+            selRect.SetCapacity(selLength);
+            for (uint32_t offset = selStart; offset < selEnd; offset++) {
+              LayoutDeviceIntRect rect;
+              if (!QueryCharRect(aWidget, offset, rect)) {
+                rect.SetEmpty();
+              }
+              selRect.AppendElement(rect);
+            }
+          }
+
+          mTextRectArray = Some(TextRectArray(selStart));
+          mTextRectArray->mRects = std::move(selRect);
+        }
+      }
+      sInLineRectCache = false;
+    }
   }
 
