+void ContentCache::OffsetAllRectsBy(LayoutDeviceIntPoint aDelta) {
+  mEditorRect.MoveBy(aDelta);
+  mFirstCharRect.MoveBy(aDelta);
+  if (mCaret) {
+    mCaret->mRect.MoveBy(aDelta);
+  }
+  if (mSelection) {
+    for (auto& rect : mSelection->mAnchorCharRects) {
+      rect.MoveBy(aDelta);
+    }
+    for (auto& rect : mSelection->mFocusCharRects) {
+      rect.MoveBy(aDelta);
+    }
+    mSelection->mRect.MoveBy(aDelta);
+  }
+  if (mTextRectArray) {
+    for (auto& rect : mTextRectArray->mRects) {
+      rect.MoveBy(aDelta);
+    }
+  }
+  if (mLastCommitStringTextRectArray) {
+    for (auto& rect : mLastCommitStringTextRectArray->mRects) {
+      rect.MoveBy(aDelta);
+    }
+  }
+}
