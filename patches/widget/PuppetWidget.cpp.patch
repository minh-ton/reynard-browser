 #include "mozilla/SchedulerGroup.h"
 #include "mozilla/TextComposition.h"
 #include "mozilla/TextEventDispatcher.h"
@@ -821,6 +822,17 @@ nsresult PuppetWidget::NotifyIMEOfPositionChange(
           !mContentCache.CacheCaretAndTextRects(this, &aIMENotification))) {
     return NS_ERROR_FAILURE;
   }
+
+  // Record the scroll offset at cache time so AdjustIMECacheForScroll
+  // can compute the correct delta later.
+  if (nsIWidgetListener* l = mWidgetListener) {
+    if (PresShell* ps = l->GetPresShell()) {
+      if (ScrollContainerFrame* sf = ps->GetRootScrollContainerFrame()) {
+        mIMELastScrollOffset = CSSPoint::FromAppUnits(sf->GetScrollPosition());
+      }
+    }
+  }
+
   if (mIMENotificationRequestsOfParent.contains(
           IMENotificationRequest::PositionChange)) {
     mBrowserChild->SendNotifyIMEPositionChange(mContentCache, aIMENotification);
@@ -830,6 +842,28 @@ nsresult PuppetWidget::NotifyIMEOfPositionChange(
   return NS_OK;
 }
 
+void PuppetWidget::AdjustIMECacheForScroll(const CSSPoint& aNewScrollOffset) {
+  if (!mBrowserChild) {
+    return;
+  }
+  CSSPoint delta = aNewScrollOffset - mIMELastScrollOffset;
+  if (delta.x == 0 && delta.y == 0) {
+    return;
+  }
+  mIMELastScrollOffset = aNewScrollOffset;
+
+  double scale = GetDefaultScale().scale;
+  LayoutDeviceIntPoint devDelta(-NSToIntRound(delta.x * scale),
+                                -NSToIntRound(delta.y * scale));
+  mContentCache.OffsetAllRectsBy(devDelta);
+
+  // Always send position change notification during scroll so the
+  // parent fires selectionGeometryChanged and UIKit updates caret/selection
+  // display.
+  widget::IMENotification notification(widget::NOTIFY_IME_OF_POSITION_CHANGE);
+  mBrowserChild->SendNotifyIMEPositionChange(mContentCache, notification);
+}
