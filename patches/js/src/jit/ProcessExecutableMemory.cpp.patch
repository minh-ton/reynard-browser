+extern "C" void* __mmap(void* addr, size_t len, int prot, int flags, int fd,
+                        off_t offset);
+
+void* reynard_mmap(void* addr, size_t len, int prot, int flags, int fd,
+                   off_t offset) {
+  void* map = __mmap(addr, len, prot, flags, fd, offset);
+  // Handle some cases where it will still map but without executable permission
+  if (mprotect(map, len, prot) == -1) {
+    munmap(map, len);
+    map = MAP_FAILED;
+  }
+  return map;
+}
+
+__attribute__((noinline, optnone, naked)) void* RequestDebuggerToPrepareRegion(
+    void* addr, size_t len) {
+  asm("mov x16, #1 \n"
+      "brk #0xf00d \n"
+      "ret");
+}
+
+static void* WritableAliasForExecutableAddress(void* addr, size_t bytes) {
+  if (!sWritableExecutableMemoryBase || !sExecutableMemoryBase) {
+    return addr;
+  }
+
+  auto* executable = static_cast<uint8_t*>(addr);
+  MOZ_RELEASE_ASSERT(executable >= sExecutableMemoryBase &&
+                     executable + bytes <=
+                         sExecutableMemoryBase + MaxCodeBytesPerProcess);
+  return sWritableExecutableMemoryBase + (executable - sExecutableMemoryBase);
+}
+
+static void PrepareExecutableRegionForExecution(void* aAddress, size_t aSize) {
+  if (!aAddress || !aSize) {
+    return;
+  }
+
+  sys_cache_control(kCacheFunctionPrepareForExecution, aAddress, aSize);
+}
+
+static void PrepareExecutableRegionForWriting(void* aAddress, size_t aSize) {
+  if (!aAddress || !aSize) {
+    return;
+  }
+
+  if (sHasTXMSupport) {
+    RequestDebuggerToPrepareRegion(aAddress, aSize);
+  }
+}
+
+static bool SetAliasProtection(void* executableAddress, void* writableAddress,
+                               size_t bytes, ProtectionSetting protection) {
+  if (!sHasTXMSupport) {
+    if (protection == ProtectionSetting::Writable) {
+      return vm_protect(mach_task_self(),
+                        reinterpret_cast<vm_address_t>(writableAddress), bytes,
+                        false, VM_PROT_READ | VM_PROT_WRITE) == KERN_SUCCESS;
+    }
+    sys_dcache_flush(writableAddress, bytes);
+    sys_icache_invalidate(executableAddress, bytes);
+    return true;
+  }
+
+  switch (protection) {
+    case ProtectionSetting::Writable:
+      if (vm_protect(mach_task_self(),
+                     reinterpret_cast<vm_address_t>(writableAddress), bytes,
+                     false, VM_PROT_READ | VM_PROT_WRITE) != KERN_SUCCESS) {
+        return false;
+      }
+      return mprotect(executableAddress, bytes, PROT_READ | PROT_EXEC) == 0;
+    case ProtectionSetting::Executable:
+      if (vm_protect(mach_task_self(),
+                     reinterpret_cast<vm_address_t>(writableAddress), bytes,
+                     false, VM_PROT_READ) != KERN_SUCCESS) {
+        return false;
+      }
+      return mprotect(executableAddress, bytes, PROT_READ | PROT_EXEC) == 0;
+  }
+  MOZ_CRASH();
+}
+#endif
