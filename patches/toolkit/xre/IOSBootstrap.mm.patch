+struct ChildBootstrapThreadArgs {
+  int argc;
+  char** argv;
+};
+
+static void* ChildBootstrapThreadMain(void* aClosure) {
+  auto* args = static_cast<ChildBootstrapThreadArgs*>(aClosure);
+  const int argc = args->argc;
+  char** argv = args->argv;
+  delete args;
+
+  pthread_set_qos_class_self_np(QOS_CLASS_USER_INITIATED, 0);
+  _exit(ChildProcessInitImpl(argc, argv));
+}
+
+static void LaunchChildBootstrapThread(int aArgc, char** aArgv) {
+  auto* args = new ChildBootstrapThreadArgs{aArgc, aArgv};
+
+  pthread_attr_t attr;
+  int rv = pthread_attr_init(&attr);
+  MOZ_RELEASE_ASSERT(rv == 0, "Failed to initialize bootstrap thread attrs");
+
+  rv = pthread_attr_setdetachstate(&attr, PTHREAD_CREATE_DETACHED);
+  MOZ_RELEASE_ASSERT(rv == 0, "Failed to detach bootstrap thread");
+
+  size_t stackSize = nsIThreadManager::LargeStackSize();
+  if (stackSize < PTHREAD_STACK_MIN) {
+    stackSize = PTHREAD_STACK_MIN;
+  }
+  rv = pthread_attr_setstacksize(&attr, stackSize);
+  MOZ_RELEASE_ASSERT(rv == 0, "Failed to size bootstrap thread stack");
+
+  pthread_t thread;
+  rv = pthread_create(&thread, &attr, ChildBootstrapThreadMain, args);
+  pthread_attr_destroy(&attr);
+
+  if (rv != 0) {
+    delete args;
+    MOZ_CRASH("Failed to create Gecko child bootstrap thread");
+  }
+}
