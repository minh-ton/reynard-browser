+// REYNARD: Recover the traits encoded in Apple system font names 
+// so the font fallback preserves the same symbolic style.
+fn hidden_system_font_traits(name: &str) -> (u32, u32) {
+    let lower = name.to_ascii_lowercase();
+    let mut trait_value = 0;
+    let mut trait_mask = 0;
+
+    if lower.contains("italic") || lower.contains("oblique") {
+        trait_value |= kCTFontItalicTrait;
+        trait_mask |= kCTFontItalicTrait;
+    }
+    if lower.contains("bold") || lower.contains("semibold") || lower.contains("demibold") {
+        trait_value |= kCTFontBoldTrait;
+        trait_mask |= kCTFontBoldTrait;
+    }
+    if lower.contains("condensed") || lower.contains("narrow") {
+        trait_value |= kCTFontCondensedTrait;
+        trait_mask |= kCTFontCondensedTrait;
+    }
+    if lower.contains("expanded") || lower.contains("extended") {
+        trait_value |= kCTFontExpandedTrait;
+        trait_mask |= kCTFontExpandedTrait;
+    }
+
+    (trait_value, trait_mask)
+}
