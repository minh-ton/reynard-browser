+#[cfg(target_os = "ios")]
+fn new_system_ui_font(
+    name: &str,
+    system_font_traits: u32,
+) -> Result<CTFont, NativeFontResolutionError> {
+    let system_font = core_text::font::new_ui_font_for_language(
+        core_text::font::kCTFontSystemFontType,
+        0.0,
+        None,
+    );
+    let trait_mask =
+        kCTFontItalicTrait | kCTFontBoldTrait | kCTFontCondensedTrait | kCTFontExpandedTrait;
+    let trait_value = system_font_traits & trait_mask;
+    if trait_value == 0 {
+        return Ok(system_font);
+    }
+    system_font
+        .clone_with_symbolic_traits(trait_value, trait_mask)
+        .ok_or_else(|| NativeFontResolutionError::SystemTraits {
+            requested: name.to_string(),
+            traits: system_font_traits,
+        })
+}
+
+fn resolve_native_font(
+    handle: &NativeFontHandle,
+) -> Result<(CTFontDescriptor, bool), NativeFontResolutionError> {
+    #[cfg(target_os = "ios")]
+    if handle.is_system_font {
+        let font = new_system_ui_font(&handle.name, handle.system_font_traits)?;
+        return Ok((font.copy_descriptor(), true));
+    }
+
+    let requested = CFString::new(&handle.name);
+    let font = CGFont::from_name(&requested).map_err(|_| {
+        NativeFontResolutionError::NotFound {
+            requested: handle.name.clone(),
+            resolved: None,
+        }
+    })?;
+    let resolved = font.postscript_name().to_string();
+    if resolved != handle.name {
+        return Err(NativeFontResolutionError::IdentityMismatch {
+            requested: handle.name.clone(),
+            resolved,
+        });
+    }
+    Ok((
+        core_text::font::new_from_CGFont(&font, 0.).copy_descriptor(),
+        false,
+    ))
 }
 
