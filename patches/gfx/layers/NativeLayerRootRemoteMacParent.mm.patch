 NativeLayerRootRemoteMacParent::RecvCommitNativeLayerCommands(
     nsTArray<NativeLayerCommand>&& aCommands) {
+  if (!mRealNativeLayerRoot) {
+    return IPC_OK();
+  }
+
   for (auto& command : aCommands) {
     switch (command.type()) {
       case NativeLayerCommand::TCommandCreateLayer: {
@@ -88,6 +104,10 @@
 
