+enum NativeFontResolutionError {
+    NotFound {
+        requested: String,
+        resolved: Option<String>,
+    },
+    IdentityMismatch {
+        requested: String,
+        resolved: String,
+    },
+    SystemTraits {
+        requested: String,
+        traits: u32,
+    },
+}
+
+impl fmt::Display for NativeFontResolutionError {
+    fn fmt(&self, formatter: &mut fmt::Formatter) -> fmt::Result {
+        match self {
+            NativeFontResolutionError::NotFound {
+                requested,
+                resolved,
+            } => write!(
+                formatter,
+                "font not found: requested {}, resolved {}",
+                requested,
+                resolved.as_deref().unwrap_or("<none>")
+            ),
+            NativeFontResolutionError::IdentityMismatch {
+                requested,
+                resolved,
+            } => write!(
+                formatter,
+                "font identity mismatch: requested {}, resolved {}",
+                requested, resolved
+            ),
+            NativeFontResolutionError::SystemTraits { requested, traits } => write!(
+                formatter,
+                "failed to apply system font traits {} to {}",
+                traits, requested
+            ),
+        }
+    }
+}
