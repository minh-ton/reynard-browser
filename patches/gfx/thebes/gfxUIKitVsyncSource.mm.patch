+#include "gfxUIKitVsyncSource.h"
+
+#include "VsyncSource.h"
+#include "gfxPlatform.h"
+#include "mozilla/DataMutex.h"
+#include "mozilla/Monitor.h"
+#include "mozilla/TimeStamp.h"
+#include "nsDebug.h"
+#include "nsObjCExceptions.h"
+#include "nsThreadUtils.h"
+
+#import <Foundation/NSInvocation.h>
+#import <QuartzCore/CAFrameRateRange.h>
+#import <QuartzCore/CADisplayLink.h>
+#import <UIKit/UIScreen.h>
+
+#include <algorithm>
+#include <cmath>
+#include <mach/mach_time.h>
+
+using mozilla::TimeDuration;
+using mozilla::TimeStamp;
+
+namespace mozilla::gfx {
+class UIKitVsyncSource;
+}
+
+@interface UIKitVsyncTarget : NSObject {
+ @private
+  mozilla::gfx::UIKitVsyncSource* mVsyncSource;
+}
+- (id)initWithVsyncSource:(mozilla::gfx::UIKitVsyncSource*)aVsyncSource;
+- (void)displayLinkFired:(CADisplayLink*)aDisplayLink;
+- (void)runDisplayLinkThread:(CADisplayLink*)aDisplayLink;
+- (void)stopDisplayLinkThread:(CADisplayLink*)aDisplayLink;
+@end
+
+namespace mozilla::gfx {
+
+static constexpr NSInteger kMinFPS = 60;
+static constexpr double kMinObservedFPS = 10.0;
+static constexpr double kFPSMargin = 0.5;
+
+static NSInteger MaxFPS(UIScreen* aScreen) {
+  return std::max(static_cast<NSInteger>([aScreen maximumFramesPerSecond]),
+                  kMinFPS);
+}
+
+static TimeStamp TimeStampFromCASeconds(CFTimeInterval aSeconds) {
+  static const mach_timebase_info_data_t timebaseInfo = [] {
+    mach_timebase_info_data_t resultInfo;
+    kern_return_t result = mach_timebase_info(&resultInfo);
+    MOZ_RELEASE_ASSERT(result == KERN_SUCCESS);
+    return resultInfo;
+  }();
+
+  double ticks =
+      (aSeconds * 1000000000.0 * timebaseInfo.denom) / timebaseInfo.numer;
+  return TimeStamp::FromSystemTime(static_cast<int64_t>(ticks));
+}
+
+class UIKitVsyncSource final : public VsyncSource {
+ public:
+  UIKitVsyncSource()
+      : mThreadMonitor("UIKitVsyncSource::mThreadMonitor"),
+        mVsyncRate(TimeDuration::FromMilliseconds(1000.0 / 60.0),
+                   "UIKitVsyncSource::mVsyncRate") {}
+
+  ~UIKitVsyncSource() override {
+    MOZ_ASSERT(NS_IsMainThread());
+    Shutdown();
+  }
+
+  void EnableVsync() override {
+    MOZ_ASSERT(NS_IsMainThread());
+    if (IsVsyncEnabled()) {
+      return;
+    }
+
+    NS_OBJC_BEGIN_TRY_IGNORE_BLOCK;
+
+    UIScreen* screen = [UIScreen mainScreen];
+    CADisplayLink* displayLink =
+        [screen displayLinkWithTarget:mTarget
+                             selector:@selector(displayLinkFired:)];
+    if (!displayLink) {
+      NS_WARNING("Could not create UIKit CADisplayLink.");
+      return;
+    }
+
+    mDisplayLink = [displayLink retain];
+    ConfigureFrameRate();
+
+    {
+      MonitorAutoLock lock(mThreadMonitor);
+      mThreadReady = false;
+      mThreadFinished = false;
+    }
+
+    mThread = [[NSThread alloc] initWithTarget:mTarget
+                                      selector:@selector(runDisplayLinkThread:)
+                                        object:mDisplayLink];
+    [mThread setName:@"UIKitVsyncThread"];
+    [mThread start];
+
+    MonitorAutoLock lock(mThreadMonitor);
+    while (!mThreadReady && !mThreadFinished) {
+      lock.Wait();
+    }
+
+    NS_OBJC_END_TRY_IGNORE_BLOCK;
+  }
+
+  void DisableVsync() override {
+    MOZ_ASSERT(NS_IsMainThread());
+    if (!mDisplayLink) {
+      return;
+    }
+
+    NS_OBJC_BEGIN_TRY_IGNORE_BLOCK;
+
+    if (mThread && ![mThread isFinished]) {
+      [mTarget performSelector:@selector(stopDisplayLinkThread:)
+                      onThread:mThread
+                    withObject:mDisplayLink
+                 waitUntilDone:YES];
+
+      MonitorAutoLock lock(mThreadMonitor);
+      while (!mThreadFinished) {
+        lock.Wait();
+      }
+    } else {
+      [mDisplayLink invalidate];
+    }
+
+    [mDisplayLink release];
+    mDisplayLink = nil;
+    [mThread release];
+    mThread = nil;
+
+    NS_OBJC_END_TRY_IGNORE_BLOCK;
+  }
+
+  bool IsVsyncEnabled() override {
+    MOZ_ASSERT(NS_IsMainThread());
+    return mDisplayLink != nil;
+  }
+
+  TimeDuration GetVsyncRate() override {
+    auto rate = mVsyncRate.Lock();
+    return *rate;
+  }
+
+  void Shutdown() override {
+    MOZ_ASSERT(NS_IsMainThread());
+    DisableVsync();
+    [mTarget release];
+    mTarget = nil;
+  }
+
+  bool Initialize() {
+    MOZ_ASSERT(NS_IsMainThread());
+
+    NS_OBJC_BEGIN_TRY_BLOCK_RETURN;
+
+    mTarget = [[UIKitVsyncTarget alloc] initWithVsyncSource:this];
+    SetVsyncRateForScreen([UIScreen mainScreen]);
+    return mTarget != nil;
+
+    NS_OBJC_END_TRY_BLOCK_RETURN(false);
+  }
+
+  void OnDisplayLinkFired(CADisplayLink* aDisplayLink) {
+    TimeStamp vsyncTime = TimeStampFromCASeconds([aDisplayLink timestamp]);
+    TimeStamp outputTime =
+        TimeStampFromCASeconds([aDisplayLink targetTimestamp]);
+    TimeStamp now = TimeStamp::Now();
+
+    UpdateVsyncRateFromDisplayLink(aDisplayLink);
+
+    if (vsyncTime > now) {
+      vsyncTime = now;
+    }
+    if (outputTime <= vsyncTime) {
+      outputTime = vsyncTime + GetVsyncRate();
+    }
+
+    VsyncSource::NotifyVsync(vsyncTime, outputTime);
+  }
+
+  void RunDisplayLinkThread(CADisplayLink* aDisplayLink) {
+    @autoreleasepool {
+      NSRunLoop* runLoop = [NSRunLoop currentRunLoop];
+      [aDisplayLink addToRunLoop:runLoop forMode:NSDefaultRunLoopMode];
+
+      {
+        MonitorAutoLock lock(mThreadMonitor);
+        mThreadReady = true;
+        lock.NotifyAll();
+      }
+
+      while (![[NSThread currentThread] isCancelled]) {
+        @autoreleasepool {
+          [runLoop runMode:NSDefaultRunLoopMode
+                beforeDate:[NSDate distantFuture]];
+        }
+      }
+
+      MonitorAutoLock lock(mThreadMonitor);
+      mThreadFinished = true;
+      lock.NotifyAll();
+    }
+  }
+
+  void StopDisplayLinkThread(CADisplayLink* aDisplayLink) {
+    [aDisplayLink invalidate];
+    [[NSThread currentThread] cancel];
+    CFRunLoopStop(CFRunLoopGetCurrent());
+  }
+
+ private:
+  void ConfigureFrameRate() {
+    UIScreen* screen = [UIScreen mainScreen];
+    SetVsyncRateForScreen(screen);
+
+    mMaxFPS = MaxFPS(screen);
+
+    if ([mDisplayLink
+            respondsToSelector:@selector(setPreferredFrameRateRange:)]) {
+#pragma clang diagnostic push
+#pragma clang diagnostic ignored "-Wunguarded-availability-new"
+      CAFrameRateRange frameRateRange =
+          CAFrameRateRangeMake(kMinFPS, mMaxFPS, mMaxFPS);
+#pragma clang diagnostic pop
+      NSInvocation* invocation = [NSInvocation
+          invocationWithMethodSignature:
+              [mDisplayLink
+                  methodSignatureForSelector:@selector(
+                                                 setPreferredFrameRateRange:)]];
+      [invocation setSelector:@selector(setPreferredFrameRateRange:)];
+      [invocation setTarget:mDisplayLink];
+      [invocation setArgument:&frameRateRange atIndex:2];
+      [invocation invoke];
+    } else {
+      mDisplayLink.preferredFramesPerSecond = mMaxFPS;
+    }
+  }
+
+  void SetVsyncRateForScreen(UIScreen* aScreen) {
+    SetVsyncRate(TimeDuration::FromMilliseconds(1000.0 / MaxFPS(aScreen)));
+  }
+
+  void UpdateVsyncRateFromDisplayLink(CADisplayLink* aDisplayLink) {
+    CFTimeInterval frameInterval =
+        [aDisplayLink targetTimestamp] - [aDisplayLink timestamp];
+
+    if (!IsValidFrameInterval(frameInterval)) {
+      frameInterval = [aDisplayLink duration];
+    }
+    if (!IsValidFrameInterval(frameInterval)) {
+      return;
+    }
+
+    SetVsyncRate(TimeDuration::FromMilliseconds(frameInterval * 1000.0));
+  }
+
+  bool IsValidFrameInterval(CFTimeInterval aFrameInterval) {
+    if (!std::isfinite(aFrameInterval) || aFrameInterval <= 0) {
+      return false;
+    }
+
+    double framesPerSecond = 1.0 / aFrameInterval;
+    return framesPerSecond >= kMinObservedFPS - kFPSMargin &&
+           framesPerSecond <= mMaxFPS + kFPSMargin;
+  }
+
+  void SetVsyncRate(const TimeDuration& aVsyncRate) {
+    auto rate = mVsyncRate.Lock();
+    *rate = aVsyncRate;
+  }
+
+  UIKitVsyncTarget* mTarget = nil;
+  CADisplayLink* mDisplayLink = nil;
+  NSThread* mThread = nil;
+  Monitor mThreadMonitor;
+  bool mThreadReady = false;
+  bool mThreadFinished = true;
+  NSInteger mMaxFPS = kMinFPS;
+  DataMutex<TimeDuration> mVsyncRate;
+};
+
+already_AddRefed<VsyncSource> CreateUIKitVsyncSource() {
+  MOZ_ASSERT(NS_IsMainThread());
+
+  RefPtr<UIKitVsyncSource> vsyncSource = new UIKitVsyncSource();
+  if (!vsyncSource->Initialize()) {
+    return nullptr;
+  }
+
+  return vsyncSource.forget();
+}
+
+}  // namespace mozilla::gfx
+
+@implementation UIKitVsyncTarget
+
+- (id)initWithVsyncSource:(mozilla::gfx::UIKitVsyncSource*)aVsyncSource {
+  self = [super init];
+  if (self) {
+    mVsyncSource = aVsyncSource;
+  }
+  return self;
+}
+
+- (void)displayLinkFired:(CADisplayLink*)aDisplayLink {
+  mVsyncSource->OnDisplayLinkFired(aDisplayLink);
+}
+
+- (void)runDisplayLinkThread:(CADisplayLink*)aDisplayLink {
+  mVsyncSource->RunDisplayLinkThread(aDisplayLink);
+}
+
+- (void)stopDisplayLinkThread:(CADisplayLink*)aDisplayLink {
+  mVsyncSource->StopDisplayLinkThread(aDisplayLink);
+}
+
+@end
