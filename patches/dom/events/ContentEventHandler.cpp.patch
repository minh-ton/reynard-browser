+// REYNARD: Detect the focused text control's anonymous editor root so iOS
+// query-content requests can use textarea scrollport-relative geometry.
+static nsTextControlFrame* GetFocusedTextControlFrameForRoot(
+    Element* aRootElement) {
+  if (!aRootElement) {
+    return nullptr;
+  }
+
+  Element* textControlRoot =
+      aRootElement->GetAnonymousRootElementOfTextEditor();
+  if (textControlRoot != aRootElement) {
+    return nullptr;
+  }
+
+  Element* textControlElement = Element::FromNodeOrNull(
+      aRootElement->GetClosestNativeAnonymousSubtreeRootParentOrHost());
+  nsTextControlFrame* textControlFrame = do_QueryFrame(
+      textControlElement ? textControlElement->GetPrimaryFrame() : nullptr);
+  if (!textControlFrame || textControlFrame->GetRootNode() != aRootElement) {
+    return nullptr;
+  }
+
+  return textControlFrame;
+}
+
+// REYNARD: Collect text control range geometry without edge-clamping so iOS
+// selection UI can disappear when the selection scrolls fully out of view.
+static bool GetUnclampedTextControlRangeRect(nsRange* aRange, nsRect& aRect) {
+  if (!aRange) {
+    return false;
+  }
+
+  nsLayoutUtils::RectAccumulator accumulator;
+  nsRange::CollectClientRectsAndText(
+      &accumulator, nullptr, aRange, aRange->GetStartContainer(),
+      aRange->StartOffset(), aRange->GetEndContainer(), aRange->EndOffset(),
+      false, false);
+  if (!accumulator.mSeenFirstRect) {
+    return false;
+  }
+
+  aRect = accumulator.mResultRect.IsEmpty() ? accumulator.mFirstRect
+                                            : accumulator.mResultRect;
+  return true;
+}
+
 // Editor places a padding <br> element under its root content if the editor
 // doesn't have any text. This happens even for single line editors.
 // When we get text content and when we change the selection,
@@ -2528,6 +2591,48 @@ nsresult ContentEventHandler::OnQueryTextRect(WidgetQueryContentEvent* aEvent) {
   }
   DOMRangeAndAdjustedOffsetInFlattenedText domRangeAndAdjustedOffset =
