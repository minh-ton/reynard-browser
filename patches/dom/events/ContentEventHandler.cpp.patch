+
+  // REYNARD: Text controls need unclamped range geometry instead of the normal
+  // edge-clamped query path used for generic editable content.
+  if (GetFocusedTextControlFrameForRoot(mRootElement)) {
+    nsRect unclampedRect;
+    IgnoredErrorResult ignoredError;
+    RefPtr<nsRange> textControlRange =
+        nsRange::Create(domRangeAndAdjustedOffset.mRange.Start(),
+                        domRangeAndAdjustedOffset.mRange.End(), ignoredError);
+    if (!ignoredError.Failed() && textControlRange &&
+        GetUnclampedTextControlRangeRect(textControlRange, unclampedRect)) {
+      nsPresContext* presContext = mRootElement->OwnerDoc()->GetPresContext();
+      if (NS_WARN_IF(!presContext)) {
+        return NS_ERROR_FAILURE;
+      }
+      aEvent->mReply->mRect = LayoutDeviceIntRect::FromAppUnitsToOutside(
+          unclampedRect, presContext->AppUnitsPerDevPixel());
+      if (nsPresContext* rootContext =
+              presContext->GetInProcessRootContentDocumentPresContext()) {
+        aEvent->mReply->mRect =
+            RoundedOut(ViewportUtils::DocumentRelativeLayoutToVisual(
+                aEvent->mReply->mRect, rootContext->PresShell()));
+      }
+      EnsureNonEmptyRect(aEvent->mReply->mRect);
+      if (nsIFrame* rootFrame = mRootElement->GetPrimaryFrame()) {
+        aEvent->mReply->mWritingMode = rootFrame->GetWritingMode();
+      }
+
+      nsString string;
+      if (NS_WARN_IF(NS_FAILED(GenerateFlatTextContent(
+              domRangeAndAdjustedOffset.mRange, string, lineBreakType)))) {
+        return NS_ERROR_FAILURE;
+      }
+      aEvent->mReply->mOffsetAndData.emplace(
+          domRangeAndAdjustedOffset.mAdjustedOffset, string,
+          OffsetAndDataFor::EditorString);
+
+      MOZ_ASSERT(aEvent->Succeeded());
+      return NS_OK;
+    }
+  }
+
   nsString string;
   if (NS_WARN_IF(NS_FAILED(GenerateFlatTextContent(
           domRangeAndAdjustedOffset.mRange, string, lineBreakType)))) {
@@ -2847,6 +2952,76 @@ nsresult ContentEventHandler::OnQueryEditorRect(
     return rv;
   }
 
+  if (nsTextControlFrame* textControlFrame =
+          GetFocusedTextControlFrameForRoot(mRootElement)) {
+    // REYNARD: Focused text controls need the live scrollport here so native
+    // UIKit selection UI can disappear once a textarea scrolls the selection
+    // fully out of view.
+    if (ScrollContainerFrame* scrollTargetFrame =
+            textControlFrame->GetScrollTargetFrame()) {
+      nsRect resultRect = scrollTargetFrame->GetScrollPortRect();
+      rv = ConvertToRootRelativeOffset(scrollTargetFrame, resultRect);
+      if (NS_SUCCEEDED(rv)) {
+        nsPresContext* presContext = scrollTargetFrame->PresContext();
+        aEvent->mReply->mRect = LayoutDeviceIntRect::FromAppUnitsToOutside(
+            resultRect, presContext->AppUnitsPerDevPixel());
+        // REYNARD: Match the visual-space transform used by caret/text rect
+        // queries so the native selection bounds stay aligned while zoomed.
+        if (nsPresContext* rootContext =
+                presContext->GetInProcessRootContentDocumentPresContext()) {
+          aEvent->mReply->mRect =
+              RoundedOut(ViewportUtils::DocumentRelativeLayoutToVisual(
+                  aEvent->mReply->mRect, rootContext->PresShell()));
+        }
+        EnsureNonEmptyRect(aEvent->mReply->mRect);
+        MOZ_ASSERT(aEvent->Succeeded());
+        return NS_OK;
+      }
+    }
+  }
+
+  // REYNARD: For contenteditable elements (which don't have a text control
+  // frame), find the nearest scroll container that clips the editor and use
+  // its scroll port rect. Without this, the editor rect for overflowing
+  // contenteditable divs would be the full element bounding rect, causing
+  // selection UI to remain visible when content is scrolled out of view.
+  if (nsIFrame* editorFrame =
+          mRootElement ? mRootElement->GetPrimaryFrame() : nullptr) {
+    ScrollContainerFrame* scf = nsLayoutUtils::GetNearestScrollContainerFrame(
+        editorFrame, nsLayoutUtils::SCROLLABLE_SAME_DOC |
+                         nsLayoutUtils::SCROLLABLE_INCLUDE_HIDDEN);
+    if (scf) {
+      nsPresContext* presContext = scf-> PresContext();
+      // Skip the root scroll container: its scroll port is just the viewport
+      // which is already handled by ChildView bounds clipping on the native
+      // side.
+      nsIFrame* rootScrollFrame = nullptr;
+      if (nsPresContext* rootContext =
+              presContext->GetInProcessRootContentDocumentPresContext()) {
+        if (PresShell* shell = rootContext->GetPresShell()) {
+          rootScrollFrame = shell->GetRootScrollContainerFrame();
+        }
+      }
+      if (scf != rootScrollFrame) {
+        nsRect scrollPort = scf->GetScrollPortRect();
+        rv = ConvertToRootRelativeOffset(scf, scrollPort);
+        if (NS_SUCCEEDED(rv)) {
+          aEvent->mReply->mRect = LayoutDeviceIntRect::FromAppUnitsToOutside(
+              scrollPort, presContext->AppUnitsPerDevPixel());
+          if (nsPresContext* rootContext =
+                  presContext->GetInProcessRootContentDocumentPresContext()) {
+            aEvent->mReply->mRect =
+                RoundedOut(ViewportUtils::DocumentRelativeLayoutToVisual(
+                    aEvent->mReply->mRect, rootContext->PresShell()));
+          }
+          EnsureNonEmptyRect(aEvent->mReply->mRect);
+          MOZ_ASSERT(aEvent->Succeeded());
+          return NS_OK;
+        }
+      }
+    }
+  }
+
   if (NS_WARN_IF(NS_FAILED(QueryContentRect(mRootElement, aEvent)))) {
     return NS_ERROR_FAILURE;
   }
