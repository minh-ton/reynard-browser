+mozilla::ipc::IPCResult BrowserChild::RecvQueryCaretRectAtOffset(
+    const uint32_t& aOffset, bool* aSucceeded, LayoutDeviceIntRect* aRect) {
+  *aSucceeded = false;
+  aRect->SetEmpty();
+
+  if (!mPuppetWidget) {
+    return IPC_OK();
+  }
+
+  WidgetQueryContentEvent queryEvent(true, eQueryCaretRect, mPuppetWidget);
+  queryEvent.InitForQueryCaretRect(aOffset);
+  mPuppetWidget->DispatchEvent(&queryEvent);
+  if (queryEvent.Failed()) {
+    if (aOffset > 0) {
+      WidgetQueryContentEvent queryTextContentEvent(true, eQueryTextContent,
+                                                    mPuppetWidget);
+      queryTextContentEvent.InitForQueryTextContent(aOffset, 1);
+      mPuppetWidget->DispatchEvent(&queryTextContentEvent);
+
+      const bool startsWithHardLineBreak =
+          !queryTextContentEvent.Failed() &&
+          !queryTextContentEvent.mReply->IsDataEmpty() &&
+          (queryTextContentEvent.mReply->DataRef()[0] == '\n' ||
+           queryTextContentEvent.mReply->DataRef()[0] == '\r');
+      if (startsWithHardLineBreak) {
+        WidgetQueryContentEvent queryPrevTextRectEvent(true, eQueryTextRect,
+                                                       mPuppetWidget);
+        queryPrevTextRectEvent.InitForQueryTextRect(aOffset - 1, 1);
+        mPuppetWidget->DispatchEvent(&queryPrevTextRectEvent);
+        if (!queryPrevTextRectEvent.Failed()) {
+          LayoutDeviceIntRect caretRect = queryPrevTextRectEvent.mReply->mRect;
+          const WritingMode& writingMode =
+              queryPrevTextRectEvent.mReply->mWritingMode;
+          if (writingMode.IsVertical()) {
+            caretRect.y = caretRect.YMost() + 1;
+            caretRect.height = 1;
+          } else {
+            caretRect.x = caretRect.XMost() + 1;
+            caretRect.width = 1;
+          }
+
+          *aSucceeded = true;
+          *aRect = caretRect;
+        }
+      }
+    }
+    return IPC_OK();
+  }
+
+  *aSucceeded = true;
+  *aRect = queryEvent.mReply->mRect;
+  return IPC_OK();
+}
