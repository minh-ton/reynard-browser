+mozilla::ipc::IPCResult BrowserChild::RecvSetSelectionRange(
+    const uint32_t& aOffset, const uint32_t& aLength, bool* aSucceeded) {
+  *aSucceeded = false;
+
+  if (!mPuppetWidget) {
+    return IPC_OK();
+  }
+
+  WidgetSelectionEvent event(true, eSetSelection, mPuppetWidget);
+  event.mOffset = aOffset;
+  event.mLength = aLength;
+  event.mExpandToClusterBoundary = false;
+  mPuppetWidget->DispatchEvent(&event);
+  if (!event.mSucceeded) {
+    return IPC_OK();
+  }
+
+  *aSucceeded = true;
+
+  WidgetQueryContentEvent queryEvent(true, eQuerySelectedText, mPuppetWidget);
+  queryEvent.InitForQuerySelectedText(SelectionType::eNormal);
+  mPuppetWidget->DispatchEvent(&queryEvent);
+  if (!queryEvent.Failed() && !queryEvent.DidNotFindSelection()) {
+    IMENotification notification(NOTIFY_IME_OF_SELECTION_CHANGE);
+    notification.mSelectionChangeData.Assign(queryEvent);
+    mPuppetWidget->NotifyIME(mPuppetWidget->GetTextEventDispatcher(),
+                             notification);
+  }
+
+  return IPC_OK();
+}
