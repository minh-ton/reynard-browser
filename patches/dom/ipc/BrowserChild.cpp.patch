+mozilla::ipc::IPCResult BrowserChild::RecvSelectWordAtPoint(
+    const LayoutDeviceIntPoint& aPoint, bool* aSucceeded) {
+  *aSucceeded = false;
+
+  if (!mPuppetWidget) {
+    return IPC_OK();
+  }
+
+  RefPtr<PresShell> presShell = GetTopLevelPresShell();
+  if (!presShell) {
+    return IPC_OK();
+  }
+
+  nsIFrame* rootFrame = presShell->GetRootFrame();
+  if (!rootFrame) {
+    return IPC_OK();
+  }
+
+  const nsPoint pointInRoot = nsLayoutUtils::GetEventCoordinatesRelativeTo(
+      mPuppetWidget, aPoint, RelativeTo{rootFrame});
+  nsIFrame* targetFrame =
+      nsLayoutUtils::GetFrameForPoint(RelativeTo{rootFrame}, pointInRoot);
+  if (!targetFrame) {
+    return IPC_OK();
+  }
+
+  const nsPoint relativePoint = nsLayoutUtils::GetEventCoordinatesRelativeTo(
+      mPuppetWidget, aPoint, RelativeTo{targetFrame});
+  *aSucceeded = NS_SUCCEEDED(targetFrame->SelectByTypeAtPoint(
+      relativePoint, eSelectWord, eSelectWord, nsIFrame::SELECT_ACCUMULATE));
+
+  if (*aSucceeded) {
+    WidgetQueryContentEvent queryEvent(true, eQuerySelectedText, mPuppetWidget);
+    queryEvent.InitForQuerySelectedText(SelectionType::eNormal);
+    mPuppetWidget->DispatchEvent(&queryEvent);
+    if (!queryEvent.Failed() && !queryEvent.DidNotFindSelection()) {
+      IMENotification notification(NOTIFY_IME_OF_SELECTION_CHANGE);
+      notification.mSelectionChangeData.Assign(queryEvent);
+      mPuppetWidget->NotifyIME(mPuppetWidget->GetTextEventDispatcher(),
+                               notification);
+    }
+  }
+  return IPC_OK();
+}
