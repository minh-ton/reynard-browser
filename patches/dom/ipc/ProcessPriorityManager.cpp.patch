+#ifdef XP_IOS
+void ProcessPriorityManagerChild::SetIOSBackgroundState(
+    ProcessPriority aPriority) {
+  int priority = 0;
+  switch (aPriority) {
+    case PROCESS_PRIORITY_BACKGROUND:
+    case PROCESS_PRIORITY_PREALLOC:
+      priority = PRIO_DARWIN_BG;
+      break;
+    case PROCESS_PRIORITY_BACKGROUND_PERCEIVABLE:
+    case PROCESS_PRIORITY_FOREGROUND_KEYBOARD:
+    case PROCESS_PRIORITY_FOREGROUND:
+    case PROCESS_PRIORITY_FOREGROUND_HIGH:
+      break;
+    case PROCESS_PRIORITY_UNKNOWN:
+    case PROCESS_PRIORITY_PARENT_PROCESS:
+    default:
+      return;
+  }
+
+  errno = 0;
+  if (setpriority(PRIO_DARWIN_PROCESS, 0, priority) == -1) {
+    LOG("setpriority(PRIO_DARWIN_PROCESS, 0, %d) failed for %s: errno=%d",
+        priority, ProcessPriorityToString(aPriority), errno);
+  }
+}
+#endif
