+IPCResult ContentParent::RecvNotifyGPUProcessLost(
+    const uint64_t& aProcessToken) {
+  // REYNARD: Route content-side abnormal compositor shutdown events through
+  // the active GPU process token so recovery targets the correct process.
+  gfx::GPUProcessManager* gpm = gfx::GPUProcessManager::Get();
+  if (gpm) {
+    gpm->NotifyRemoteActorDestroyed(aProcessToken);
+  }
+  return IPC_OK();
+}
